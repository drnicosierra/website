---
import Layout from "../layouts/Layout.astro";
import { getImage } from 'astro:assets';

const heroImage = await getImage({ src: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=1800&h=1200&q=85&fit=crop', width: 1800, height: 1200, format: 'webp' });
const queEsImage = await getImage({ src: 'https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=800&h=600&q=80&fit=crop', width: 800, height: 600, format: 'webp' });

const schemaBlocks = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Cirugía de Revisión",
  "procedureType": "Surgical",
  "bodyLocation": "Labio, Paladar, Nariz",
  "indication": {
    "@type": "MedicalIndication",
    "name": "Fisura labiopalatina"
  },
  "preparation": "Valoración exhaustiva del caso previo con análisis fotográfico, funcional y estético. Diseño de plan individualizado para las secuelas de cada paciente.",
  "followup": "Seguimiento postoperatorio con controles fotográficos seriados. Coordinación con logopedia y otros especialistas según el caso.",
  "howPerformed": "Técnica adaptada a cada caso. El Dr. Sierra analiza el resultado previo y diseña una corrección individualizada de labio, nariz, paladar o combinaciones.",
  "performer": {
    "@type": "Physician",
    "name": "Dr. Nico Sierra",
    "url": "https://www.drnicosierra.com",
    "medicalSpecialty": "Oral and Maxillofacial Surgery",
    "affiliation": {
      "@type": "MedicalOrganization",
      "name": "Clinica Tresserra",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Barcelona",
        "addressCountry": "ES"
      }
    }
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿A qué edad se opera el labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sí. La cirugía de revisión puede mejorar asimetrías, cicatrices prominentes, deficiencias de volumen o deformidades residuales. El Dr. Nico Sierra realiza una valoración completa para determinar qué es posible mejorar en cada caso con expectativas realistas antes de cualquier intervención."}
    },
    {
      "@type": "Question",
      "name": "¿Qué técnica utiliza el Dr. Nico Sierra para la reconstrucción de labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "La cirugía de revisión puede realizarse a cualquier edad. En niños, algunos procedimientos se planifican en momentos específicos del desarrollo. En adolescentes y adultos, no existe límite de edad para buscar una mejora. El Dr. Sierra adapta el plan al momento vital de cada paciente."}
    },
    {
      "@type": "Question",
      "name": "¿Se puede operar el labio fisurado en adultos?",
      "acceptedAnswer": {"@type": "Answer", "text": "El número depende de la complejidad del caso y los objetivos del paciente. El Dr. Sierra planifica siempre el mínimo número de intervenciones necesarias para el mejor resultado posible, minimizando el impacto sobre los tejidos ya operados."}
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo dura la recuperación tras la cirugía de labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "La cirugía en tejido previamente operado presenta desafíos específicos de cicatrización y vascularización. Con amplia experiencia en casos complejos, el Dr. Sierra evalúa minuciosamente cada caso y adapta la técnica para minimizar riesgos."}
    },
    {
      "@type": "Question",
      "name": "¿La cirugía de labio fisurado afecta a la nariz?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sí. El Dr. Sierra recibe frecuentemente pacientes operados en otros países. La valoración inicial puede realizarse por telemedicina. El equipo coordina la logística del viaje y el seguimiento postoperatorio a distancia."}
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Inicio","item":"https://www.drnicosierra.com/"},
    {"@type":"ListItem","position":2,"name":"Cómo te ayudamos","item":"https://www.drnicosierra.com/como-te-ayudamos/"},
    {"@type":"ListItem","position":3,"name":"Cirugía de Revisión","item":"https://www.drnicosierra.com/cirugia-revision-fisura/"}
  ]
}
</script>`;
const title = 'Cirugía de Revisión Fisura Labiopalatina | Dr. Nico Sierra España';
const description = 'El Dr. Nico Sierra es especialista en cirugía de revisión de fisura labiopalatina. Corrección de resultados previos en niños y adultos. Barcelona. Cuéntanos tu caso.';
const canonical = 'https://www.drnicosierra.com/cirugia-revision-fisura/';
const ogTitle = 'Cirugía de Revisión FLP | Dr. Nico Sierra Barcelona';
const ogDescription = 'Especialista en corrección de resultados previos de labio fisurado y paladar hendido. Casos complejos. Barcelona.';
const ogImage = 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=1200&q=80&fit=crop';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription} ogImage={ogImage} schemaBlocks={schemaBlocks}>
  <Fragment slot="head" set:html={`
<!-- Fonts -->

<style>
  :root { --sc:#0d74c4; --sc-soft:rgba(13,116,196,0.12); --sc-glow:rgba(13,116,196,0.2); }
</style>
`} />
  <Fragment set:html={`
<!-- ═══════════════════════════════════════════
   BREADCRUMB (visible + semantic, per brief)
   ═══════════════════════════════════════════ -->
<div class="breadcrumb">
  <nav aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span class="sep">›</span>
    <a href="/como-te-ayudamos">Cómo te ayudamos</a>
    <span class="sep">›</span>
    <span class="current">Cirugía de Revisión</span>
  </nav>
</div>

<!-- ═══════════════════════════════════════════
   BLOCK 1 — HERO
   H1 must contain primary keyword
   No autoplay video — image only
   ═══════════════════════════════════════════ -->
<section class="hero" aria-labelledby="hero-h1">
  <div class="hero-bg">
    <!-- REPLACE src with service-specific hero image -->
    <img src="${heroImage.src}" alt="Cirugía de reconstrucción de labio fisurado — Dr. Nico Sierra Barcelona">
    <div class="hero-veil"></div>
  </div>
  <div class="hero-accent" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="sh">
      <div class="eyebrow hero-fade" style="--rv:0ms">Fisura labiopalatina · Barcelona</div>
      <h1 id="hero-h1" class="hero-fade" style="--rv:60ms">Cirugía de <em>revisión</em> en fisura labiopalatina</h1>
      <p class="lead hero-fade" style="--rv:120ms">Corrección de resultados previos de labio fisurado, paladar hendido y secuelas asociadas. El Dr. Nico Sierra es especialista en casos complejos en niños, adolescentes y adultos.</p>
    </div>
    <div class="hero-ctas hero-fade" style="--rv:180ms">
      <a href="/cuentanos-tu-historia" class="btn btn-service">Cuéntanos tu caso →</a>
      <a href="https://wa.me/WHATSAPP_NUMBER" class="btn btn-wa" data-wa-loc="hero">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zM12 20.5a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5z"/></svg>
        WhatsApp
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 2 — QUÉ ES
   AEO: first paragraph = self-contained answer
   for featured snippet "¿Qué es [procedure]?"
   ═══════════════════════════════════════════ -->
<section class="section que-es" aria-labelledby="que-es-h2">
  <div class="container">
    <div class="que-es-grid">
      <div class="que-es-text">
        <div class="sh">
          <div class="eyebrow reveal">¿Qué es?</div>
          <h2 id="que-es-h2" class="reveal rv2">¿Qué es cirugía de revisión?</h2>
        </div>
        <!-- AEO: first paragraph must stand alone as a complete answer -->
        <div class="reveal rv3">
          <p>La cirugía de revisión en fisura labiopalatina es el conjunto de procedimientos dirigidos a corregir resultados insatisfactorios de cirugías previas. El objetivo es mejorar la función, la estética y la calidad de vida de pacientes que no quedaron conformes con intervenciones anteriores de labio fisurado, paladar hendido o secuelas asociadas.</p>
          <p>Las secuelas susceptibles de revisión incluyen asimetrías del labio, cicatrices visibles, deformidad nasal, fístulas palatinas, insuficiencia velofaríngea y secuelas funcionales en el habla o la respiración. Cada caso requiere un análisis individualizado sin protocolos estándar.</p>
          <p>El Dr. Nico Sierra es especialista de referencia en cirugía de revisión de fisura labiopalatina en España, recibiendo casos complejos de toda España y del extranjero que buscan mejorar resultados de intervenciones previas.</p>
        </div>
      </div>
      <div class="que-es-img reveal-scale rv2">
        <!-- REPLACE src with procedure-specific image -->
        <img src="${queEsImage.src}" alt="Cirugía de labio fisurado fisura labiopalatina — Dr. Nico Sierra Barcelona">
        <div class="que-es-img-placeholder" aria-hidden="true" style="display:none">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          <span>IMAGEN_{'labio-fisurado'.upper().replace('-','_')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 3 — CUÁNDO SE INDICA
   AEO: each bullet = complete sentence (per brief)
   ═══════════════════════════════════════════ -->
<section class="section cuando" aria-labelledby="cuando-h2">
  <div class="container">
    <div class="sh" style="max-width:720px">
      <div class="eyebrow reveal">Indicaciones</div>
      <h2 id="cuando-h2" class="reveal rv2">¿Cuándo se recomienda la cirugía de revisión?</h2>
      <p class="lead reveal rv3">La cirugía de revisión está indicada cuando el resultado de una intervención previa no es satisfactorio estética o funcionalmente. No existe límite de edad.</p>
    </div>
    <div class="cuando-list">
      <!-- Each item: complete sentence, not a fragment (AEO requirement) -->
      <div class="cuando-item reveal rv2">
        <div class="cuando-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <div class="cuando-text">
          <h4>Asimetría o cicatriz del labio</h4>
          <p>La revisión está indicada cuando existe asimetría visible, una cicatriz prominente o un resultado estético mejorable, independientemente de la edad del paciente.</p>
        </div>
      </div>
      <div class="cuando-item reveal rv3">
        <div class="cuando-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <div class="cuando-text">
          <h4>Deformidad nasal asociada</h4>
          <p>La deformidad nasal es frecuente en pacientes con labio fisurado. La rinoplastia específica para FLP puede realizarse de forma independiente o combinada con la revisión del labio.</p>
        </div>
      </div>
      <div class="cuando-item reveal rv4">
        <div class="cuando-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="cuando-text">
          <h4>Fístula o insuficiencia velofaríngea</h4>
          <p>Las fístulas palatinas y la insuficiencia velofaríngea son secuelas frecuentes de la cirugía de paladar hendido que requieren revisión quirúrgica para mejorar la función del habla.</p>
        </div>
      </div>
      <div class="cuando-item reveal rv5">
        <div class="cuando-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="cuando-text">
          <h4>Adultos con secuelas no abordadas</h4>
          <p>Muchos adultos llegan con secuelas nunca tratadas o minusvaloradas. El Dr. Sierra ofrece valoraciones honestas sobre qué es posible mejorar. Nunca es tarde.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 4 — EL PROCESO QUIRÚRGICO
   AEO: include specific timeframes per brief
   ═══════════════════════════════════════════ -->
<section class="section proceso" aria-labelledby="proceso-h2">
  <div class="container">
    <div style="max-width:720px">
      <div class="sh" style="max-width:720px">
        <div class="eyebrow reveal">Cómo es la cirugía</div>
        <h2 id="proceso-h2" class="reveal rv2">¿Cómo es la cirugía de revisión?</h2>
        <p class="lead reveal rv3">La cirugía de revisión se planifica siempre de forma individualizada. No existen protocolos estándar — cada plan responde a las necesidades específicas del paciente.</p>
      </div>
    </div>
    <div class="proceso-steps reveal rv2">
      <div class="proceso-step">
        <div class="proceso-num">01</div>
        <div class="proceso-content">
          <h3>Valoración detallada del caso</h3>
          <p>Análisis fotográfico, funcional y estético del resultado previo. El Dr. Sierra establece qué es posible mejorar y fija expectativas realistas para cada caso.</p>
          <span class="timeframe">Consulta presencial o telemática</span>
        </div>
      </div>
      <div class="proceso-step">
        <div class="proceso-num">02</div>
        <div class="proceso-content">
          <h3>Plan quirúrgico personalizado</h3>
          <p>Diseño de la estrategia de revisión: tipo de corrección, técnica, momento óptimo y posibles combinaciones con otras intervenciones.</p>
          <span class="timeframe">Previo a la cirugía</span>
        </div>
      </div>
      <div class="proceso-step">
        <div class="proceso-num">03</div>
        <div class="proceso-content">
          <h3>La intervención de revisión</h3>
          <p>Cirugía bajo anestesia general o local según el caso. La duración varía entre 1 y 4 horas según complejidad y estructuras a corregir.</p>
          <span class="timeframe">1 – 4 horas según complejidad</span>
        </div>
      </div>
      <div class="proceso-step">
        <div class="proceso-num">04</div>
        <div class="proceso-content">
          <h3>Seguimiento y resultado</h3>
          <p>Controles postoperatorios con valoración fotográfica seriada. El resultado final se evalúa a los 12-18 meses de la intervención.</p>
          <span class="timeframe">Seguimiento a 12-18 meses</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 5 — RESULTADOS / ANTES Y DESPUÉS
   Before/after image placeholders per brief
   ═══════════════════════════════════════════ -->
<section class="section resultados" aria-labelledby="resultados-h2">
  <div class="container">
    <div class="sh" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px">
      <div>
        <div class="eyebrow reveal">Vidas Transformadas</div>
        <h2 id="resultados-h2" class="reveal rv2">¿Qué resultados se pueden esperar?</h2>
        <p class="lead reveal rv2">Los resultados de la cirugía de revisión dependen de la complejidad del caso y del resultado previo. El Dr. Sierra siempre ofrece una valoración honesta de lo que es posible mejorar.</p>
      </div>
      <a href="/vidas-transformadas" class="reveal" style="font-size:.82rem;color:rgba(255,255,255,.3);transition:color .2s;flex-shrink:0;padding-top:4px">Ver todos →</a>
    </div>
    <div class="ba-grid">
      <div class="ba-card reveal rv2">
        <div class="ba-images">
          <!-- REPLACE with real before/after images -->
          <div class="ba-img">ANTES</div>
          <div class="ba-img">DESPUÉS</div>
        </div>
        <div class="ba-body">
          <div class="ba-tag">Revisión de labio</div>
          <div class="ba-title">Corrección de asimetría y cicatriz</div>
          <div class="ba-meta">Adulto 28 años · Barcelona</div>
        </div>
      </div>
      <div class="ba-card reveal rv3">
        <div class="ba-images">
          <div class="ba-img">ANTES</div>
          <div class="ba-img">DESPUÉS</div>
        </div>
        <div class="ba-body">
          <div class="ba-tag">Revisión + rinoplastia</div>
          <div class="ba-title">Revisión de labio y nariz en un tiempo</div>
          <div class="ba-meta">Adolescente 16 años · Madrid</div>
        </div>
      </div>
      <div class="ba-card reveal rv4">
        <div class="ba-images">
          <div class="ba-img">ANTES</div>
          <div class="ba-img">DESPUÉS</div>
        </div>
        <div class="ba-body">
          <div class="ba-tag">Fístula palatina</div>
          <div class="ba-title">Cierre de fístula compleja tras 2 intentos previos</div>
          <div class="ba-meta">Adulto 34 años · Internacional</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 6 — DR. SIERRA EN ESTA INTERVENCIÓN
   AEO: named entities per brief
   Must contain ≥2 named entities: UFPR, CHOP,
   Operation Smile, FEBOMFS, Springer
   ═══════════════════════════════════════════ -->
<section class="section dr-section" aria-labelledby="dr-h2">
  <div class="container">
    <div class="dr-inner">
      <!-- Left column -->
      <div class="dr-left">
        <div class="sh">
          <div class="eyebrow reveal">¿Por qué el Dr. Nico Sierra?</div>
          <h2 id="dr-h2" class="reveal rv2">¿Por qué elegir al Dr. Nico Sierra para cirugía de revisión?</h2>
          <p class="lead reveal rv3">El Dr. Nico Sierra es el único cirujano en España con fellowship en Cirugía Craneofacial y Fisura Labiopalatina, completado en la Universidad Federal de Paraná (UFPR), Brasil, uno de los centros de referencia mundial para esta disciplina.</p>
        </div>
        <p class="reveal rv3">Su experiencia incluye colaboración con Operation Smile y Smile Train en más de cuatro continentes, así como la publicación de un capítulo en Springer sobre cirugía de fisura labiopalatina en contextos de baja dotación de recursos.</p>
        <div class="reveal rv4" style="margin-top:20px">
          <span class="entity-tag">UFPR · Brasil</span>
          <span class="entity-tag">Operation Smile</span>
          <span class="entity-tag">Smile Train</span>
          <span class="entity-tag">Springer</span>
        </div>
        <div class="dr-stats reveal rv4">
          <div class="dr-stat">
            <div class="dr-stat-num">+1.000</div>
            <div class="dr-stat-label">cirugías FLP</div>
          </div>
          <div class="dr-stat">
            <div class="dr-stat-num">+200</div>
            <div class="dr-stat-label">cirugías de revisión</div>
          </div>
        </div>
      </div>
      <!-- Right column -->
      <div class="dr-right reveal-scale rv3">
        <blockquote class="dr-quote">
          "La cirugía de revisión es la más exigente técnicamente. Requiere entender profundamente qué pasó antes, qué es posible mejorar y cómo hacerlo con el menor impacto adicional."
        </blockquote>
        <a href="/sobre-dr-nico-sierra" class="btn btn-ghost" style="margin-top:28px;display:inline-flex;">Conoce al Dr. Nico Sierra →</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 7 — FAQ
   AEO CRITICAL: H3 = question, P = answer
   No nested divs between H3 and P (per brief)
   Schema text must match visible text exactly
   Answers must open by restating question topic
   ═══════════════════════════════════════════ -->
<section class="section faq" aria-labelledby="faq-h2">
  <div class="container">
    <div class="sh">
      <div class="eyebrow reveal">Preguntas frecuentes</div>
      <h2 id="faq-h2" class="reveal rv2">Preguntas frecuentes sobre cirugía de revisión</h2>
    </div>
    <div class="faq-layout">
      <div class="faq-intro reveal rv3">
        <p>Estas son las preguntas que más nos hacen las familias sobre cirugía de revisión. Si no encuentras la respuesta que buscas, escríbenos directamente.</p>
        <a href="/cuentanos-tu-historia" class="btn btn-service">Hacer una pregunta →</a>
      </div>
      <div class="faq-list">

        <details class="faq-item reveal">
          <summary>
            <h3>¿Se puede mejorar el resultado de una cirugía previa de labio fisurado?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer"><p>Sí. La cirugía de revisión puede mejorar asimetrías, cicatrices prominentes, deficiencias de volumen o deformidades residuales. El Dr. Nico Sierra realiza una valoración completa para determinar qué es posible mejorar en cada caso con expectativas realistas antes de cualquier intervención.</p></div>
        </details>

        <details class="faq-item reveal rv2">
          <summary>
            <h3>¿A qué edad se puede hacer una cirugía de revisión?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer"><p>La cirugía de revisión puede realizarse a cualquier edad. En niños, algunos procedimientos se planifican en momentos específicos del desarrollo. En adolescentes y adultos, no existe límite de edad para buscar una mejora. El Dr. Sierra adapta el plan al momento vital de cada paciente.</p></div>
        </details>

        <details class="faq-item reveal rv3">
          <summary>
            <h3>¿Cuántas cirugías de revisión son necesarias?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer"><p>El número depende de la complejidad del caso y los objetivos del paciente. El Dr. Sierra planifica siempre el mínimo número de intervenciones necesarias para el mejor resultado posible, minimizando el impacto sobre los tejidos ya operados.</p></div>
        </details>

        <details class="faq-item reveal rv4">
          <summary>
            <h3>¿Es arriesgado operar en una zona previamente intervenida?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer"><p>La cirugía en tejido previamente operado presenta desafíos específicos de cicatrización y vascularización. Con amplia experiencia en casos complejos, el Dr. Sierra evalúa minuciosamente cada caso y adapta la técnica para minimizar riesgos.</p></div>
        </details>

