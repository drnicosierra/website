---
import Layout from "../layouts/Layout.astro";

const schemaBlocks = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Rinoplastia en FLP",
  "procedureType": "Surgical",
  "bodyLocation": "Nariz",
  "indication": {
    "@type": "MedicalIndication",
    "name": "Fisura labiopalatina"
  },
  "preparation": "Análisis fotográfico y funcional completo de la nariz. Valoración de la permeabilidad nasal y función respiratoria. Planificación del abordaje quirúrgico.",
  "followup": "Controles postoperatorios con fotografías seriadas. Valoración del resultado estético y funcional a los 3, 6 y 12 meses.",
  "howPerformed": "Rinoplastia abierta o cerrada según el caso, con técnicas específicas para la anatomía nasal de la fisura labiopalatina. Corrección del septo, cartílagos alares y punta nasal.",
  "performer": {
    "@type": "Physician",
    "name": "Dr. Nico Sierra",
    "url": "https://www.drnicosierra.com",
    "medicalSpecialty": "Oral and Maxillofacial Surgery",
    "affiliation": {
      "@type": "MedicalOrganization",
      "name": "Clinica Tresserra",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Barcelona",
        "addressCountry": "ES"
      }
    }
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿A qué edad se opera el labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "La nariz de los pacientes con FLP presenta una anatomía específica con asimetría de los cartílagos alares, desviación del septo y aplastamiento de la aleta nasal. Las técnicas de rinoplastia convencional no están diseñadas para esta anatomía. El Dr. Nico Sierra utiliza técnicas específicas para la rinoplastia en FLP que abordan estas particularidades y consiguen resultados naturales."}
    },
    {
      "@type": "Question",
      "name": "¿Qué técnica utiliza el Dr. Nico Sierra para la reconstrucción de labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "La rinoplastia definitiva en FLP se realiza habitualmente cuando el crecimiento nasal está completo, a partir de los 16-17 años. En adolescentes con obstrucción nasal significativa, puede estar indicada una corrección funcional del septo antes. El Dr. Sierra evalúa cada caso para determinar el momento óptimo."}
    },
    {
      "@type": "Question",
      "name": "¿Se puede operar el labio fisurado en adultos?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sí. La rinoplastia en FLP aborda tanto la estética como la función respiratoria. La corrección del septo desviado y la mejora de la permeabilidad nasal son objetivos prioritarios en muchos casos. El Dr. Sierra evalúa la función respiratoria en todos los pacientes antes de planificar la intervención."}
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo dura la recuperación tras la cirugía de labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sí. En muchos pacientes, la rinoplastia puede realizarse en el mismo acto quirúrgico que la revisión del labio fisurado, cuando ambas correcciones están indicadas simultáneamente. El Dr. Sierra planifica la estrategia más adecuada para cada caso, considerando las ventajas de realizarlas juntas o en tiempos separados."}
    },
    {
      "@type": "Question",
      "name": "¿La cirugía de labio fisurado afecta a la nariz?",
      "acceptedAnswer": {"@type": "Answer", "text": "Tras la rinoplastia en FLP el paciente lleva férula nasal durante 7-10 días. La inflamación y los hematomas se resuelven en 2-3 semanas. Se mantiene reposo relativo durante 2-3 semanas. El resultado nasal evoluciona durante los primeros 12-18 meses hasta su forma definitiva."}
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Inicio","item":"https://www.drnicosierra.com/"},
    {"@type":"ListItem","position":2,"name":"Cómo te ayudamos","item":"https://www.drnicosierra.com/como-te-ayudamos/"},
    {"@type":"ListItem","position":3,"name":"Rinoplastia en FLP","item":"https://www.drnicosierra.com/rinoplastia-flp/"}
  ]
}
</script>`;
const title = 'Rinoplastia en Fisura Labiopalatina | Dr. Nico Sierra España';
const description = 'El Dr. Nico Sierra es especialista en rinoplastia para fisura labiopalatina en España. Reconstrucción nasal funcional y estética. Barcelona.';
const canonical = 'https://www.drnicosierra.com/rinoplastia-flp/';
const ogTitle = 'Rinoplastia en FLP | Dr. Nico Sierra Barcelona';
const ogDescription = 'Especialista en rinoplastia funcional y estética para fisura labiopalatina en Barcelona. Reconstrucción nasal específica para pacientes con FLP.';
const ogImage = 'https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=1200&q=80&fit=crop';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription} ogImage={ogImage} schemaBlocks={schemaBlocks}>
