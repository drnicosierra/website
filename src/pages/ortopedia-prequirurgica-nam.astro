const ogDescription = 'Moldeado nasoalveolar (NAM) para bebés con fisura labiopalatina. Preparación óptima antes de la cirugía primaria de labio fisurado.';
const ogImage = 'https://images.unsplash.com/photo-1584515933487-779824d29309?w=1200&q=80&fit=crop';
