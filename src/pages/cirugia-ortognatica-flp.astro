---
import Layout from "../layouts/Layout.astro";

const schemaBlocks = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Cirugía Ortognática en FLP",
  "procedureType": "Surgical",
  "bodyLocation": "Maxilar, Mandíbula",
  "indication": {
    "@type": "MedicalIndication",
    "name": "Fisura labiopalatina"
  },
  "preparation": "Planificación cefalométrica y con modelos de estudio. Ortodoncia prequirúrgica de 12-18 meses para descompensar la oclusión. Simulación 3D del resultado.",
  "followup": "Ortodoncia postquirúrgica de 6-12 meses para finalizar la oclusión. Seguimiento del resultado estético y funcional a largo plazo.",
  "howPerformed": "Osteotomía de Le Fort I para el maxilar superior, combinada o no con osteotomía mandibular según el caso. Técnica adaptada a las particularidades anatómicas de cada paciente con FLP.",
  "performer": {
    "@type": "Physician",
    "name": "Dr. Nico Sierra",
    "url": "https://www.drnicosierra.com",
    "medicalSpecialty": "Oral and Maxillofacial Surgery",
    "affiliation": {
      "@type": "MedicalOrganization",
      "name": "Clinica Tresserra",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Barcelona",
        "addressCountry": "ES"
      }
    }
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿A qué edad se opera el labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "La cirugía ortognática en fisura labiopalatina corrige la posición de los maxilares cuando la fisura ha alterado el crecimiento facial. En estos pacientes, el maxilar superior suele presentar un déficit de proyección, causando maloclusión clase III y alteración de la armonía facial. El Dr. Nico Sierra adapta la técnica a las particularidades anatómicas de cada paciente con FLP."}
    },
    {
      "@type": "Question",
      "name": "¿Qué técnica utiliza el Dr. Nico Sierra para la reconstrucción de labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "La cirugía ortognática se realiza cuando el crecimiento facial está completo, habitualmente a partir de los 16-17 años en mujeres y los 18-19 años en hombres. Antes de esa edad, el crecimiento residual puede comprometer el resultado a largo plazo. El Dr. Sierra evalúa cada caso individualmente para determinar el momento óptimo."}
    },
    {
      "@type": "Question",
      "name": "¿Se puede operar el labio fisurado en adultos?",
      "acceptedAnswer": {"@type": "Answer", "text": "El tratamiento completo incluye 12-18 meses de ortodoncia prequirúrgica, la cirugía propiamente dicha y 6-12 meses de ortodoncia postquirúrgica para finalizar la oclusión. El proceso total dura habitualmente entre 2 y 3 años, con la cirugía en la mitad del recorrido."}
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo dura la recuperación tras la cirugía de labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sí. La presencia de cicatrices del paladar, la vascularización alterada y la anatomía específica de los pacientes con FLP presentan desafíos técnicos que no existen en la cirugía ortognática convencional. El Dr. Sierra está especializado en estas particularidades y adapta la técnica para minimizar los riesgos y maximizar el resultado."}
    },
    {
      "@type": "Question",
      "name": "¿La cirugía de labio fisurado afecta a la nariz?",
      "acceptedAnswer": {"@type": "Answer", "text": "En algunos pacientes con FLP, la corrección de la posición del maxilar puede mejorar aspectos del habla relacionados con la oclusión. Sin embargo, los problemas del habla de origen velofaríngeo no se corrigen con ortognática — requieren una evaluación logopédica independiente. El Dr. Sierra coordina la valoración del habla con los especialistas correspondientes."}
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Inicio","item":"https://www.drnicosierra.com/"},
    {"@type":"ListItem","position":2,"name":"Cómo te ayudamos","item":"https://www.drnicosierra.com/como-te-ayudamos/"},
    {"@type":"ListItem","position":3,"name":"Cirugía Ortognática en FLP","item":"https://www.drnicosierra.com/cirugia-ortognatica-flp/"}
  ]
}
</script>`;
const title = 'Cirugía Ortognática Fisura Labiopalatina | Dr. Nico Sierra España';
const description = 'El Dr. Nico Sierra es especialista en cirugía ortognática para pacientes con fisura labiopalatina en España. Corrección maxilomandibular. Barcelona.';
const canonical = 'https://www.drnicosierra.com/cirugia-ortognatica-flp/';
const ogTitle = 'Cirugía Ortognática en FLP | Dr. Nico Sierra Barcelona';
const ogDescription = 'Especialista en cirugía ortognática para fisura labiopalatina en Barcelona. Corrección de la posición de los maxilares y armonía facial.';
const ogImage = 'https://images.unsplash.com/photo-1579154204601-01588f351e67?w=1200&q=80&fit=crop';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription} ogImage={ogImage} schemaBlocks={schemaBlocks}>
