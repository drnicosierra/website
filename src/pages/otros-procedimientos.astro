---
import Layout from "../layouts/Layout.astro";
import { getImage } from 'astro:assets';

const heroImage = await getImage({ src: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=1800&h=1200&q=85&fit=crop', width: 1800, height: 1200, format: 'webp' });
const queEsImage = await getImage({ src: 'https://images.unsplash.com/photo-1584515933487-779824d29309?w=800&h=600&q=80&fit=crop', width: 800, height: 600, format: 'webp' });

const schemaBlocks = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Otros Procedimientos",
  "procedureType": "Surgical",
  "bodyLocation": "Variable según procedimiento",
  "indication": {
    "@type": "MedicalIndication",
    "name": "Fisura labiopalatina"
  },
  "preparation": "Evaluación individualizada según el procedimiento específico de cada caso.",
  "followup": "Seguimiento personalizado adaptado al procedimiento y las necesidades de cada paciente.",
  "howPerformed": "Técnica adaptada al procedimiento específico de cada caso, siempre dentro del contexto del tratamiento integral de la fisura labiopalatina.",
  "performer": {
    "@type": "Physician",
    "name": "Dr. Nico Sierra",
    "url": "https://www.drnicosierra.com",
    "medicalSpecialty": "Oral and Maxillofacial Surgery",
    "affiliation": {
      "@type": "MedicalOrganization",
      "name": "Clinica Tresserra",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Barcelona",
        "addressCountry": "ES"
      }
    }
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿A qué edad se opera el labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "Además de los ocho tratamientos principales, el Dr. Nico Sierra realiza faringoplastias para insuficiencia velofaríngea, cierres de fístulas complejas, procedimientos de aumento de volumen labial, corrección de cicatrices queloides y otras intervenciones secundarias dentro del tratamiento integral de la fisura labiopalatina."}
    },
    {
      "@type": "Question",
      "name": "¿Qué técnica utiliza el Dr. Nico Sierra para la reconstrucción de labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "La faringoplastia es un procedimiento quirúrgico que mejora el cierre del velo del paladar en pacientes con insuficiencia velofaríngea persistente tras la cirugía de paladar hendido. Está indicada cuando el habla nasal no mejora con logopedia y afecta significativamente a la comunicación y la calidad de vida."}
    },
    {
      "@type": "Question",
      "name": "¿Se puede operar el labio fisurado en adultos?",
      "acceptedAnswer": {"@type": "Answer", "text": "Si tu situación no encaja exactamente en ninguno de los tratamientos descritos en nuestra web, escríbenos directamente. El Dr. Sierra revisa personalmente cada caso y responde con orientación específica. No existe un caso demasiado complejo o inusual para ser valorado."}
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo dura la recuperación tras la cirugía de labio fisurado?",
      "acceptedAnswer": {"@type": "Answer", "text": "Sí. El tratamiento integral de la fisura labiopalatina requiere la coordinación con ortodontistas, logopedas, otorrinolaringólogos, y otros especialistas. El Dr. Sierra trabaja en equipo y coordina con los profesionales necesarios para cada caso."}
    },
    {
      "@type": "Question",
      "name": "¿La cirugía de labio fisurado afecta a la nariz?",
      "acceptedAnswer": {"@type": "Answer", "text": "El tiempo de organización varía según la complejidad del caso. Habitualmente, el Dr. Sierra responde a las consultas iniciales en menos de 24 horas. La planificación completa de casos complejos puede requerir varias consultas y coordinación con otros especialistas, pero el proceso es siempre transparente y el paciente está informado en cada paso."}
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Inicio","item":"https://www.drnicosierra.com/"},
    {"@type":"ListItem","position":2,"name":"Cómo te ayudamos","item":"https://www.drnicosierra.com/como-te-ayudamos/"},
    {"@type":"ListItem","position":3,"name":"Otros Procedimientos","item":"https://www.drnicosierra.com/otros-procedimientos/"}
  ]
}
</script>`;
const title = 'Otros Procedimientos Fisura Labiopalatina | Dr. Nico Sierra España';
const description = 'El Dr. Nico Sierra trata todos los procedimientos relacionados con la fisura labiopalatina. ¿No encuentras lo que buscas? Cuéntanos tu caso en Barcelona.';
const canonical = 'https://www.drnicosierra.com/otros-procedimientos/';
const ogTitle = 'Otros Procedimientos FLP | Dr. Nico Sierra Barcelona';
const ogDescription = 'Procedimientos complementarios para fisura labiopalatina en Barcelona. Cuéntanos tu caso y el Dr. Sierra te orientará.';
const ogImageOptimized = await getImage({ src: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=1200&h=630&q=80&fit=crop', width: 1200, height: 630, format: 'jpg' });
const ogImage = new URL(ogImageOptimized.src, Astro.site).href;
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription} ogImage={ogImage} schemaBlocks={schemaBlocks}>
  <Fragment slot="head" set:html={`
<!-- Fonts -->

<style>
  :root { --sc:#64748B; --sc-soft:rgba(100,116,139,0.12); --sc-glow:rgba(100,116,139,0.2); }
</style>
`} />
  <Fragment set:html={`
<!-- ═══════════════════════════════════════════
   BREADCRUMB (visible + semantic, per brief)
   ═══════════════════════════════════════════ -->
<div class="breadcrumb">
  <nav aria-label="Ruta de navegación">
    <a href="/">Inicio</a>
    <span class="sep">›</span>
    <a href="/como-te-ayudamos">Cómo te ayudamos</a>
    <span class="sep">›</span>
    <span class="current">Otros Procedimientos</span>
  </nav>
</div>

<!-- ═══════════════════════════════════════════
   BLOCK 1 — HERO
   H1 must contain primary keyword
   No autoplay video — image only
   ═══════════════════════════════════════════ -->
<section class="hero" aria-labelledby="hero-h1">
  <div class="hero-bg">
    <!-- REPLACE src with service-specific hero image -->
    <img src="${heroImage.src}" alt="Cirugía de reconstrucción de labio fisurado — Dr. Nico Sierra Barcelona">
    <div class="hero-veil"></div>
  </div>
  <div class="hero-accent" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="sh">
      <div class="eyebrow hero-fade" style="--rv:0ms">Fisura labiopalatina · Barcelona</div>
      <h1 id="hero-h1" class="hero-fade" style="--rv:60ms">Otros <em>procedimientos</em> en fisura labiopalatina</h1>
      <p class="lead hero-fade" style="--rv:120ms">Procedimientos complementarios dentro del tratamiento integral de la fisura labiopalatina. Si no encuentras lo que buscas, cuéntanos tu caso.</p>
    </div>
    <div class="hero-ctas hero-fade" style="--rv:180ms">
      <a href="/cuentanos-tu-historia" class="btn btn-service">Cuéntanos tu caso →</a>
      <a href="https://wa.me/WHATSAPP_NUMBER" class="btn btn-wa" data-wa-loc="hero">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zM12 20.5a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5z"/></svg>
        WhatsApp
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 2 — QUÉ ES
   AEO: first paragraph = self-contained answer
   for featured snippet "¿Qué es [procedure]?"
   ═══════════════════════════════════════════ -->
<section class="section que-es" aria-labelledby="que-es-h2">
  <div class="container">
    <div class="que-es-grid">
      <div class="que-es-text">
        <div class="sh">
          <div class="eyebrow reveal">¿Qué es?</div>
          <h2 id="que-es-h2" class="reveal rv2">¿Qué es otros procedimientos?</h2>
        </div>
        <!-- AEO: first paragraph must stand alone as a complete answer -->
        <div class="reveal rv3">
          <p>El tratamiento de la fisura labiopalatina es un recorrido largo y multidisciplinar que puede incluir procedimientos complementarios más allá de las ocho intervenciones principales. El Dr. Nico Sierra aborda todos los aspectos del tratamiento integral de la fisura, coordinando con otros especialistas cuando es necesario.</p>
          <p>Entre los procedimientos complementarios más frecuentes se encuentran: faringoplastia para la insuficiencia velofaríngea, cierre de fístulas oronasales complejas, procedimientos de aumento de volumen labial, cicatrices queloides, intervenciones de logopedia quirúrgica y otras correcciones secundarias.</p>
          <p>Si no encuentras en la lista de tratamientos principales lo que necesitas, escríbenos directamente. El Dr. Sierra revisa personalmente cada caso y te orienta sobre las opciones disponibles para tu situación específica.</p>
        </div>
      </div>
      <div class="que-es-img reveal-scale rv2">
        <!-- REPLACE src with procedure-specific image -->
        <img src="${queEsImage.src}" alt="Cirugía de labio fisurado fisura labiopalatina — Dr. Nico Sierra Barcelona">
        <div class="que-es-img-placeholder" aria-hidden="true" style="display:none">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          <span>IMAGEN_{'labio-fisurado'.upper().replace('-','_')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 3 — CUÁNDO SE INDICA
   AEO: each bullet = complete sentence (per brief)
   ═══════════════════════════════════════════ -->
<section class="section cuando" aria-labelledby="cuando-h2">
  <div class="container">
    <div class="sh" style="max-width:720px">
      <div class="eyebrow reveal">Indicaciones</div>
      <h2 id="cuando-h2" class="reveal rv2">¿Cuándo se recomienda la otros procedimientos?</h2>
      <p class="lead reveal rv3">Los procedimientos complementarios se indican cuando las intervenciones principales no han resuelto completamente todos los aspectos de la fisura labiopalatina.</p>
    </div>
    <div class="cuando-list">
      <!-- Each item: complete sentence, not a fragment (AEO requirement) -->
      <div class="cuando-item reveal rv2">
        <div class="cuando-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <div class="cuando-text">
          <h4>Insuficiencia velofaríngea residual</h4>
          <p>La faringoplastia está indicada cuando persiste insuficiencia velofaríngea tras el cierre del paladar, causando un habla nasal que no mejora con logopedia.</p>
        </div>
      </div>
      <div class="cuando-item reveal rv3">
        <div class="cuando-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <div class="cuando-text">
          <h4>Fístulas oronasales complejas</h4>
          <p>El cierre de fístulas oronasales complejas o recidivantes puede requerir técnicas avanzadas de reconstrucción con colgajos locales o regionales.</p>
        </div>
      </div>
      <div class="cuando-item reveal rv4">
        <div class="cuando-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="cuando-text">
          <h4>Secuelas estéticas secundarias</h4>
          <p>El volumen labial reducido, las cicatrices queloides o las deformidades menores pueden tratarse con procedimientos complementarios adaptados a cada caso.</p>
        </div>
      </div>
      <div class="cuando-item reveal rv5">
        <div class="cuando-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="cuando-text">
          <h4>Casos no contemplados en los tratamientos principales</h4>
          <p>Cada paciente con fisura labiopalatina es único. Si tu caso no encaja exactamente en ninguno de los tratamientos descritos, cuéntanoslo y el Dr. Sierra te orientará.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 4 — EL PROCESO QUIRÚRGICO
   AEO: include specific timeframes per brief
   ═══════════════════════════════════════════ -->
<section class="section proceso" aria-labelledby="proceso-h2">
  <div class="container">
    <div style="max-width:720px">
      <div class="sh" style="max-width:720px">
        <div class="eyebrow reveal">Cómo es la cirugía</div>
        <h2 id="proceso-h2" class="reveal rv2">¿Cómo es la otros procedimientos?</h2>
        <p class="lead reveal rv3">Los procedimientos complementarios se planifican siempre de forma individualizada, adaptando la técnica y el momento a las necesidades específicas de cada paciente.</p>
      </div>
    </div>
    <div class="proceso-steps reveal rv2">
      <div class="proceso-step">
        <div class="proceso-num">01</div>
        <div class="proceso-content">
          <h3>Cuéntanos tu caso</h3>
          <p>Escríbenos con una descripción de tu situación y fotos si es posible. El Dr. Sierra lo revisa personalmente y responde con orientación específica para tu caso.</p>
          <span class="timeframe">Respuesta en menos de 24h</span>
        </div>
      </div>
      <div class="proceso-step">
        <div class="proceso-num">02</div>
        <div class="proceso-content">
          <h3>Valoración personalizada</h3>
          <p>Consulta presencial o telemática para analizar en detalle tu caso y determinar qué procedimiento es más adecuado para tu situación.</p>
          <span class="timeframe">Consulta individual</span>
        </div>
      </div>
      <div class="proceso-step">
        <div class="proceso-num">03</div>
        <div class="proceso-content">
          <h3>Planificación del procedimiento</h3>
          <p>Diseño del plan específico para tu caso: técnica, momento óptimo, combinación con otros procedimientos si es necesario.</p>
          <span class="timeframe">Planificación individualizada</span>
        </div>
      </div>
      <div class="proceso-step">
        <div class="proceso-num">04</div>
        <div class="proceso-content">
          <h3>Seguimiento personalizado</h3>
          <p>El Dr. Sierra hace un seguimiento cercano de todos sus pacientes, independientemente del procedimiento realizado.</p>
          <span class="timeframe">Seguimiento continuo</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 5 — RESULTADOS / ANTES Y DESPUÉS
   Before/after image placeholders per brief
   ═══════════════════════════════════════════ -->
<section class="section resultados" aria-labelledby="resultados-h2">
  <div class="container">
    <div class="sh" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px">
      <div>
        <div class="eyebrow reveal">Vidas Transformadas</div>
        <h2 id="resultados-h2" class="reveal rv2">¿Qué resultados se pueden esperar?</h2>
        <p class="lead reveal rv2">Los procedimientos complementarios completan el tratamiento integral de la fisura labiopalatina, abordando los aspectos que las intervenciones principales no han resuelto completamente.</p>
      </div>
      <a href="/vidas-transformadas" class="reveal" style="font-size:.82rem;color:rgba(255,255,255,.3);transition:color .2s;flex-shrink:0;padding-top:4px">Ver todos →</a>
    </div>
    <div class="ba-grid">
      <div class="ba-card reveal rv2">
        <div class="ba-images">
          <!-- REPLACE with real before/after images -->
          <div class="ba-img">ANTES</div>
          <div class="ba-img">DESPUÉS</div>
        </div>
        <div class="ba-body">
          <div class="ba-tag">Faringoplastia</div>
          <div class="ba-title">Corrección de insuficiencia velofaríngea</div>
          <div class="ba-meta">Adulto 18 años · Barcelona</div>
        </div>
      </div>
      <div class="ba-card reveal rv3">
        <div class="ba-images">
          <div class="ba-img">ANTES</div>
          <div class="ba-img">DESPUÉS</div>
        </div>
        <div class="ba-body">
          <div class="ba-tag">Fístula compleja</div>
          <div class="ba-title">Cierre con colgajo local tras múltiples intentos</div>
          <div class="ba-meta">Paciente 12 años · Madrid</div>
        </div>
      </div>
      <div class="ba-card reveal rv4">
        <div class="ba-images">
          <div class="ba-img">ANTES</div>
          <div class="ba-img">DESPUÉS</div>
        </div>
        <div class="ba-body">
          <div class="ba-tag">Otros procedimientos</div>
          <div class="ba-title">Tu caso es único — cuéntanoslo</div>
          <div class="ba-meta">Contacta con el Dr. Sierra</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 6 — DR. SIERRA EN ESTA INTERVENCIÓN
   AEO: named entities per brief
   Must contain ≥2 named entities: UFPR, CHOP,
   Operation Smile, FEBOMFS, Springer
   ═══════════════════════════════════════════ -->
<section class="section dr-section" aria-labelledby="dr-h2">
  <div class="container">
    <div class="dr-inner">
      <!-- Left column -->
      <div class="dr-left">
        <div class="sh">
          <div class="eyebrow reveal">¿Por qué el Dr. Nico Sierra?</div>
          <h2 id="dr-h2" class="reveal rv2">¿Por qué elegir al Dr. Nico Sierra para otros procedimientos?</h2>
          <p class="lead reveal rv3">El Dr. Nico Sierra es el único cirujano en España con fellowship en Cirugía Craneofacial y Fisura Labiopalatina, completado en la Universidad Federal de Paraná (UFPR), Brasil, uno de los centros de referencia mundial para esta disciplina.</p>
        </div>
        <p class="reveal rv3">Su experiencia incluye colaboración con Operation Smile y Smile Train en más de cuatro continentes, así como la publicación de un capítulo en Springer sobre cirugía de fisura labiopalatina en contextos de baja dotación de recursos.</p>
        <div class="reveal rv4" style="margin-top:20px">
          <span class="entity-tag">UFPR · Brasil</span>
          <span class="entity-tag">Operation Smile</span>
          <span class="entity-tag">Smile Train</span>
          <span class="entity-tag">Springer</span>
        </div>
        <div class="dr-stats reveal rv4">
          <div class="dr-stat">
            <div class="dr-stat-num">+1.000</div>
            <div class="dr-stat-label">cirugías FLP</div>
          </div>
          <div class="dr-stat">
            <div class="dr-stat-num">+1.000</div>
            <div class="dr-stat-label">pacientes atendidos</div>
          </div>
        </div>
      </div>
      <!-- Right column -->
      <div class="dr-right reveal-scale rv3">
        <blockquote class="dr-quote">
          "Cada paciente con fisura labiopalatina es único. Si no encuentras lo que buscas en nuestra lista de tratamientos, cuéntanoslo. Siempre hay una respuesta."
        </blockquote>
        <a href="/sobre-dr-nico-sierra" class="btn btn-ghost" style="margin-top:28px;display:inline-flex;">Conoce al Dr. Nico Sierra →</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
   BLOCK 7 — FAQ
   AEO CRITICAL: H3 = question, P = answer
   No nested divs between H3 and P (per brief)
   Schema text must match visible text exactly
   Answers must open by restating question topic
   ═══════════════════════════════════════════ -->
<section class="section faq" aria-labelledby="faq-h2">
  <div class="container">
    <div class="sh">
      <div class="eyebrow reveal">Preguntas frecuentes</div>
      <h2 id="faq-h2" class="reveal rv2">Preguntas frecuentes sobre otros procedimientos</h2>
    </div>
    <div class="faq-layout">
      <div class="faq-intro reveal rv3">
        <p>Estas son las preguntas que más nos hacen las familias sobre otros procedimientos. Si no encuentras la respuesta que buscas, escríbenos directamente.</p>
        <a href="/cuentanos-tu-historia" class="btn btn-service">Hacer una pregunta →</a>
      </div>
      <div class="faq-list">

        <details class="faq-item reveal">
          <summary>
            <h3>¿Qué otros procedimientos trata el Dr. Sierra relacionados con FLP?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer"><p>Además de los ocho tratamientos principales, el Dr. Nico Sierra realiza faringoplastias para insuficiencia velofaríngea, cierres de fístulas complejas, procedimientos de aumento de volumen labial, corrección de cicatrices queloides y otras intervenciones secundarias dentro del tratamiento integral de la fisura labiopalatina.</p></div>
        </details>

        <details class="faq-item reveal rv2">
          <summary>
            <h3>¿Qué es la faringoplastia y cuándo se indica?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer"><p>La faringoplastia es un procedimiento quirúrgico que mejora el cierre del velo del paladar en pacientes con insuficiencia velofaríngea persistente tras la cirugía de paladar hendido. Está indicada cuando el habla nasal no mejora con logopedia y afecta significativamente a la comunicación y la calidad de vida.</p></div>
        </details>

        <details class="faq-item reveal rv3">
          <summary>
            <h3>¿Qué hacer si mi caso no encaja en ninguno de los tratamientos principales?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer"><p>Si tu situación no encaja exactamente en ninguno de los tratamientos descritos en nuestra web, escríbenos directamente. El Dr. Sierra revisa personalmente cada caso y responde con orientación específica. No existe un caso demasiado complejo o inusual para ser valorado.</p></div>
        </details>

        <details class="faq-item reveal rv4">
          <summary>
            <h3>¿El Dr. Sierra coordina con otros especialistas?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer"><p>Sí. El tratamiento integral de la fisura labiopalatina requiere la coordinación con ortodontistas, logopedas, otorrinolaringólogos, y otros especialistas. El Dr. Sierra trabaja en equipo y coordina con los profesionales necesarios para cada caso.</p></div>
        </details>

        <details class="faq-item reveal rv5">
          <summary>
            <h3>¿Cuánto tiempo lleva organizar el tratamiento de un caso complejo?</h3>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
