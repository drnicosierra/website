---
import Layout from "../layouts/Layout.astro";

const title = 'Cómo te Ayudamos — Tratamientos Fisura Labiopalatina | Dr. Nico Sierra';
const description = 'El Dr. Nico Sierra trata todas las etapas de la fisura labiopalatina: NAM, labio fisurado, paladar hendido, revisión, encía, ortognática y rinoplastia. Barcelona.';
const canonical = 'https://www.drnicosierra.com/como-te-ayudamos/';
const ogTitle = 'Tratamientos Fisura Labiopalatina | Dr. Nico Sierra Barcelona';
const ogDescription = 'Todos los tratamientos de fisura labiopalatina en un único especialista. Barcelona.';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription}>
  <Fragment slot="head" set:html={`
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
`} />
  <Fragment set:html={`
<main>
<section style="min-height:50vh;background:#001629;display:flex;align-items:flex-end;padding:120px clamp(20px,4vw,48px) 80px;position:relative;">
  <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,18,41,0.9) 0%,rgba(0,18,41,0.7) 100%);"></div>
  <div style="max-width:1200px;margin:0 auto;width:100%;position:relative;z-index:1;">
    <div class="sh">
      <div class="eyebrow" style="color:#4db896;">Tratamientos</div>
      <h1>Cómo podemos ayudarte</h1>
      <p class="lead">El Dr. Sierra trata todas las etapas de la fisura labiopalatina — desde el moldeado prequirúrgico hasta la cirugía de revisión en adultos.</p>
    </div>
  </div>
</section>
<section class="section" style="background:#001e2e;">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
      <a href="/ortopedia-prequirurgica-nam/" style="display:flex;flex-direction:column;padding:28px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-top:2px solid #7C3AED;border-radius:16px;text-decoration:none;transition:background .25s,transform .25s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none'">
  <span style="font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#7C3AED;margin-bottom:12px;">01</span>
  <h3 style="font-size:1.1rem;color:#fff;margin-bottom:8px;">Ortopedia Pre-operatoria NAM</h3>
  <p style="font-size:.9rem;flex:1;">Moldeado nasoalveolar prequirúrgico para bebés con fisura labiopalatina.</p>
  <span style="font-size:.82rem;font-weight:600;color:#7C3AED;margin-top:16px;">Ver tratamiento →</span>
</a>
<a href="/cirugia-labio-fisurado/" style="display:flex;flex-direction:column;padding:28px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-top:2px solid #a01255;border-radius:16px;text-decoration:none;transition:background .25s,transform .25s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none'">
  <span style="font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#a01255;margin-bottom:12px;">02</span>
  <h3 style="font-size:1.1rem;color:#fff;margin-bottom:8px;">Reconstrucción de Labio Fisurado</h3>
  <p style="font-size:.9rem;flex:1;">Cirugía primaria y de revisión del labio fisurado en todas las edades.</p>
  <span style="font-size:.82rem;font-weight:600;color:#a01255;margin-top:16px;">Ver tratamiento →</span>
</a>
<a href="/cirugia-paladar-hendido/" style="display:flex;flex-direction:column;padding:28px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-top:2px solid #008362;border-radius:16px;text-decoration:none;transition:background .25s,transform .25s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none'">
  <span style="font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#008362;margin-bottom:12px;">03</span>
  <h3 style="font-size:1.1rem;color:#fff;margin-bottom:8px;">Reconstrucción de Paladar Hendido</h3>
  <p style="font-size:.9rem;flex:1;">Cierre del paladar hendido para el habla, la alimentación y la audición.</p>
  <span style="font-size:.82rem;font-weight:600;color:#008362;margin-top:16px;">Ver tratamiento →</span>
</a>
<a href="/cirugia-revision-fisura/" style="display:flex;flex-direction:column;padding:28px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-top:2px solid #0d74c4;border-radius:16px;text-decoration:none;transition:background .25s,transform .25s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none'">
  <span style="font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#0d74c4;margin-bottom:12px;">04</span>
  <h3 style="font-size:1.1rem;color:#fff;margin-bottom:8px;">Cirugía de Revisión</h3>
  <p style="font-size:.9rem;flex:1;">Corrección de resultados previos en niños, adolescentes y adultos.</p>
  <span style="font-size:.82rem;font-weight:600;color:#0d74c4;margin-top:16px;">Ver tratamiento →</span>
</a>
<a href="/injerto-oseo-alveolar/" style="display:flex;flex-direction:column;padding:28px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-top:2px solid #16A34A;border-radius:16px;text-decoration:none;transition:background .25s,transform .25s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none'">
  <span style="font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#16A34A;margin-bottom:12px;">05</span>
  <h3 style="font-size:1.1rem;color:#fff;margin-bottom:8px;">Reconstrucción de Encía</h3>
  <p style="font-size:.9rem;flex:1;">Injerto óseo alveolar para completar el arco dental definitivo.</p>
  <span style="font-size:.82rem;font-weight:600;color:#16A34A;margin-top:16px;">Ver tratamiento →</span>
</a>
<a href="/cirugia-ortognatica-flp/" style="display:flex;flex-direction:column;padding:28px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-top:2px solid #B45309;border-radius:16px;text-decoration:none;transition:background .25s,transform .25s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none'">
  <span style="font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#B45309;margin-bottom:12px;">06</span>
  <h3 style="font-size:1.1rem;color:#fff;margin-bottom:8px;">Cirugía Ortognática en FLP</h3>
  <p style="font-size:.9rem;flex:1;">Corrección de la posición de los maxilares en pacientes con FLP.</p>
  <span style="font-size:.82rem;font-weight:600;color:#B45309;margin-top:16px;">Ver tratamiento →</span>
</a>
<a href="/rinoplastia-flp/" style="display:flex;flex-direction:column;padding:28px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-top:2px solid #0891B2;border-radius:16px;text-decoration:none;transition:background .25s,transform .25s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none'">
  <span style="font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#0891B2;margin-bottom:12px;">07</span>
  <h3 style="font-size:1.1rem;color:#fff;margin-bottom:8px;">Rinoplastia en FLP</h3>
  <p style="font-size:.9rem;flex:1;">Reconstrucción nasal funcional y estética para fisura labiopalatina.</p>
  <span style="font-size:.82rem;font-weight:600;color:#0891B2;margin-top:16px;">Ver tratamiento →</span>
</a>
<a href="/otros-procedimientos/" style="display:flex;flex-direction:column;padding:28px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-top:2px solid #64748B;border-radius:16px;text-decoration:none;transition:background .25s,transform .25s;" onmouseover="this.style.background='rgba(255,255,255,0.07)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none'">
  <span style="font-size:.72rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#64748B;margin-bottom:12px;">08</span>
  <h3 style="font-size:1.1rem;color:#fff;margin-bottom:8px;">Otros procedimientos</h3>
  <p style="font-size:.9rem;flex:1;">Procedimientos complementarios. ¿No encuentras lo que buscas?</p>
  <span style="font-size:.82rem;font-weight:600;color:#64748B;margin-top:16px;">Ver tratamiento →</span>
</a>
    </div>
  </div>
</section>
</main>
`} />
</Layout>
