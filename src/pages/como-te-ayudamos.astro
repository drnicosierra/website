---
import Layout from "../layouts/Layout.astro";

const title = 'Cómo te Ayudamos — Tratamientos Fisura Labiopalatina | Dr. Nico Sierra';
const description = 'El Dr. Nico Sierra trata todas las etapas de la fisura labiopalatina: NAM, labio fisurado, paladar hendido, revisión, encía, ortognática y rinoplastia. Barcelona.';
const canonical = 'https://www.drnicosierra.com/como-te-ayudamos/';
const ogTitle = 'Tratamientos Fisura Labiopalatina | Dr. Nico Sierra Barcelona';
const ogDescription = 'Todos los tratamientos de fisura labiopalatina en un único especialista. Barcelona.';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription}>
  <Fragment slot="head" set:html={`
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   SHARED DESIGN SYSTEM — same as homepage
   SERVICE COLOR: change --sc here and entire page recolors
   ═══════════════════════════════════════════════════ */
:root {
  --ns-blue-900:#001829;
  --ns-blue-800:#001e3a;
  --ns-blue-700:#002d52;
  --ns-blue-600:#003a63;
  --ns-blue-500:#005085;
  --ns-blue-400:#0d74c4;
  --ns-teal-600:#008362;
  --ns-teal-300:#4db896;
  --ns-ink:#e8edf2;
  --ns-ink-soft:rgba(200,218,235,0.75);
  --ns-line:rgba(255,255,255,0.08);
  --ns-surface-1:rgba(255,255,255,0.04);
  --ns-surface-2:rgba(255,255,255,0.07);
  --ns-white:#ffffff;
  --ns-whatsapp:#25D366;
  --ns-radius:14px;
  --ns-radius-lg:22px;
  --ns-shadow-sm:0 2px 12px rgba(0,0,0,0.2);
  --ns-shadow-md:0 8px 40px rgba(0,0,0,0.35);
  --ns-ease:cubic-bezier(.22,.61,.36,1);
  --ns-container:1240px;

  /* ══ SERVICE COLOR — change this one value per page ══
     01 NAM:              #7C3AED (purple)
     02 Labio fisurado:   #C9186A (magenta)
     03 Paladar hendido:  #008362 (teal)
     04 Revisión:         #0d74c4 (blue)
     05 Encía:            #16A34A (green)
     06 Ortognática:      #B45309 (amber)
     07 Rinoplastia:      #0891B2 (cyan)
     08 Otros:            #64748B (slate)
  */
  --sc: #a01255;
  --sc-muted: #7d0e42;
  --sc-soft: rgba(160,18,85,0.12);
  --sc-glow: rgba(160,18,85,0.2);
}

*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body {
  font-family:'Space Grotesk',system-ui,sans-serif;
  background:#001629;
  color:var(--ns-ink);
  -webkit-font-smoothing:antialiased;
  line-height:1.6;
  min-height:100vh;
}
img { max-width:100%; display:block; }
a { text-decoration:none; color:inherit; }
button { font:inherit; cursor:pointer; border:0; background:none; color:inherit; }

/* Typography */
h1,h2,h3,h4 {
  font-family:'DM Sans',system-ui,sans-serif;
  color:var(--ns-white);
  letter-spacing:-.02em; line-height:1.08; font-weight:500; margin:0;
}
h1 { font-size:clamp(2.4rem,5.5vw,4.5rem); letter-spacing:-.035em; }
h2 { font-size:clamp(1.8rem,3.2vw,3rem); letter-spacing:-.025em; }
h3 { font-size:clamp(1.2rem,1.6vw,1.5rem); letter-spacing:-.015em; font-weight:500; }
h4 { font-size:1rem; font-weight:600; }
/* ── TYPOGRAPHY ── */
.eyebrow {
  font-size:.72rem; font-weight:600; letter-spacing:.22em; text-transform:uppercase;
  color:var(--sc); display:inline-flex; align-items:center; gap:.6rem;
  margin-bottom:0;        /* never set margin on eyebrow itself — .sh controls gaps */
}
.eyebrow::before { content:""; width:28px; height:2px; background:var(--sc); border-radius:2px; }
.lead { font-size:1.05rem; color:var(--ns-ink-soft); line-height:1.8; max-width:58ch; }
p { color:var(--ns-ink-soft); line-height:1.8; margin:0; }
p + p { margin-top:16px; }
strong { color:var(--ns-white); font-weight:600; }
h1,h2,h3,h4 { margin:0; }
/* Paragraphs directly after headings outside .sh */
h2 + p, h2 + .lead { margin-top:16px; }
h1 + p, h1 + .lead { margin-top:16px; }
h3 + p { margin-top:8px; }
h4 + p { margin-top:4px; }

/* ── SECTION HEADER BLOCK (.sh) ──
   Wraps eyebrow + h2 + optional lead.
   Controls ALL spacing between those elements.
   This is the ONLY place gaps are defined.
   Never use margin-top inline on h2 or p inside sections.
*/
.sh {
  margin-bottom:var(--sp-lg);   /* 40px below header before content */
}
.sh .eyebrow { display:inline-flex; }
p + p { margin-top:16px; }
.sh--center { text-align:center; }
.sh--center .eyebrow { justify-content:center; }

/* Tighter gap when .sh leads into paragraphs (not a card grid) */
.que-es-text .sh { margin-bottom:24px; }

/* Layout */
.container { max-width:var(--ns-container); margin:0 auto; padding:0 clamp(20px,4vw,48px); }
.section { padding:clamp(72px,9vw,120px) 0; }

/* Buttons */
.btn {
  display:inline-flex; align-items:center; gap:.6rem;
  padding:14px 26px; border-radius:999px;
  font-family:'DM Sans',sans-serif; font-weight:500; font-size:.95rem;
  transition:all .25s var(--ns-ease); cursor:pointer; border:none;
}
.btn-primary { background:var(--ns-blue-400); color:#fff; box-shadow:0 6px 20px rgba(13,116,196,.25); }
.btn-primary:hover { background:var(--ns-blue-500); transform:translateY(-1px); box-shadow:0 10px 28px rgba(13,116,196,.32); }
.btn-service { background:var(--sc); color:#fff; box-shadow:0 6px 20px var(--sc-glow); }
.btn-service:hover { filter:brightness(1.1); transform:translateY(-1px); }
.btn-ghost { background:transparent; color:#fff; border:1px solid rgba(255,255,255,.45); }
.btn-ghost:hover { background:rgba(255,255,255,.08); border-color:#fff; }
.btn-wa {
  background:transparent; color:#fff;
  border:1px solid rgba(255,255,255,.45);
  position:relative;
}
.btn-wa:hover { background:rgba(37,211,102,.15); border-color:#25D366; }
.btn-wa::after {
  content:'Respondemos en < 24h';
  position:absolute; bottom:calc(100% + 10px); left:50%; transform:translateX(-50%);
  background:#25D366; color:#fff; font-size:.7rem; font-weight:600;
  white-space:nowrap; padding:5px 11px; border-radius:6px;
  opacity:0; pointer-events:none; transition:opacity .2s;
}
.btn-wa:hover::after { opacity:1; }

/* Reveal animations */
.reveal { opacity:0; transform:translateY(22px); transition:opacity .8s var(--ns-ease) var(--rv,0ms), transform .8s var(--ns-ease) var(--rv,0ms); }
.reveal.visible { opacity:1; transform:none; }
.reveal-scale { opacity:0; transform:scale(0.97); transition:opacity .8s var(--ns-ease), transform .8s var(--ns-ease); }
.reveal-scale.visible { opacity:1; transform:scale(1); }
.rv2 { --rv:100ms } .rv3 { --rv:200ms } .rv4 { --rv:300ms } .rv5 { --rv:400ms }

/* ════════════════════════════════════
   NAVBAR (identical to homepage)
   ════════════════════════════════════ */
.nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  height:80px; display:flex; align-items:center;
  background:rgba(0,22,38,0.3); backdrop-filter:blur(8px);
  border-bottom:1px solid rgba(0,131,98,0.2);
  transition:background .35s var(--ns-ease), border-color .35s;
}
.nav.scrolled {
  background:rgba(0,18,36,0.92);
  border-bottom-color:rgba(0,131,98,0.25);
  box-shadow:0 1px 0 rgba(255,255,255,0.04);
}
.nav-inner {
  max-width:var(--ns-container); width:100%; margin:0 auto;
  padding:0 clamp(20px,4vw,48px);
  display:flex; align-items:center; justify-content:space-between;
}
.nav-logo img { height:72px; width:auto; }
.nav-links { display:flex; align-items:center; gap:32px; list-style:none; }
.nav-links a {
  font-size:.88rem; font-weight:500; color:rgba(210,235,225,0.85);
  transition:color .2s; padding:4px 0; position:relative;
}
.nav-links a:hover { color:#fff; }
/* Active service highlight */
.nav-links a.active {
  color:var(--sc) !important;
}
.nav-links a.active::after {
  content:''; position:absolute; bottom:-2px; left:0; right:0;
  height:1.5px; background:var(--sc); border-radius:2px;
}
.nav-cta {
  background:var(--ns-teal-600) !important; color:#fff !important;
  padding:10px 20px; border-radius:999px; font-size:.88rem !important;
  font-weight:600 !important;
}
.nav-cta:hover { background:var(--ns-blue-500) !important; }

/* ════════════════════════════════════
   BREADCRUMB (above hero, per brief)
   ════════════════════════════════════ */
.breadcrumb {
  position:relative; z-index:10;
  padding:88px clamp(20px,4vw,48px) 0;
  max-width:var(--ns-container); margin:0 auto;
}
.breadcrumb nav {
  display:flex; align-items:center; gap:8px;
  font-size:.78rem; color:rgba(255,255,255,0.4); letter-spacing:.02em;
}
.breadcrumb a { color:rgba(255,255,255,0.4); transition:color .2s; }
.breadcrumb a:hover { color:rgba(255,255,255,0.75); }
.breadcrumb .sep { opacity:.3; }
.breadcrumb .current { color:var(--sc); }

/* ════════════════════════════════════
   HERO — Block 1
   ════════════════════════════════════ */
.hero {
  position:relative; min-height:75vh;
  display:flex; align-items:flex-end;
  overflow:hidden; color:#fff;
  padding-bottom:clamp(56px,7vw,96px);
}
.hero-bg {
  position:absolute; inset:0; z-index:0;
  background:var(--ns-blue-900);
  overflow:hidden;
}
.hero-bg img {
  width:100%; height:100%; object-fit:cover; object-position:center;
  opacity:0.4; display:block;
}
.hero-veil {
  position:absolute; inset:0;
  background:
    linear-gradient(180deg, rgba(0,18,30,.5) 0%, rgba(0,18,30,.1) 40%, rgba(0,18,30,.85) 100%),
    linear-gradient(90deg, rgba(0,18,30,.8) 0%, rgba(0,18,30,.2) 60%);
}
/* Service color accent on hero left edge */
.hero-accent {
  position:absolute; left:0; top:0; bottom:0;
  width:3px; background:linear-gradient(180deg, transparent 0%, var(--sc) 40%, transparent 100%);
  z-index:2;
}
.hero-content {
  position:relative; z-index:2;
  width:100%; max-width:var(--ns-container); margin:0 auto;
  padding:0 clamp(20px,4vw,48px);
}
.hero h1 { max-width:760px; margin-bottom:20px; }
.hero h1 em { font-style:normal; color:var(--sc); }
.hero .lead { margin-bottom:36px; max-width:580px; }
.hero-ctas { display:flex; gap:12px; flex-wrap:wrap; }

/* ════════════════════════════════════
   QUÉ ES — Block 2
   ════════════════════════════════════ */
.que-es { background:#001e2e; }
.que-es-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(48px,6vw,96px); align-items:start;
}
.que-es-img {
  border-radius:var(--ns-radius-lg); overflow:hidden;
  aspect-ratio:4/3; background:var(--ns-surface-1);
  border:1px solid var(--ns-line); position:relative;
}
.que-es-img img {
  width:100%; height:100%; object-fit:cover; display:block;
}
.que-es-img-placeholder {
  width:100%; height:100%;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:12px; color:rgba(255,255,255,0.2); font-size:.8rem;
  letter-spacing:.1em; text-transform:uppercase;
  background:linear-gradient(135deg, rgba(255,255,255,0.02) 0%, var(--sc-soft) 100%);
}
/* AEO: first paragraph standalone answer */
.que-es-text p:first-of-type {
  font-size:1.05rem; color:rgba(200,218,235,0.9);
  line-height:1.8; font-weight:400;
}
.que-es-text p + p { margin-top:16px; }

/* ════════════════════════════════════
   CUÁNDO SE INDICA — Block 3
   ════════════════════════════════════ */
.cuando { background:#001629; }
.cuando-list {
  display:flex; flex-direction:column; gap:16px; margin-top:48px;
}
.cuando-item {
  display:flex; align-items:flex-start; gap:20px;
  padding:22px 24px;
  background:var(--ns-surface-1); border:1px solid var(--ns-line);
  border-left:3px solid var(--sc);
  border-radius:var(--ns-radius);
  transition:background .25s, border-color .25s;
}
.cuando-item:hover { background:var(--ns-surface-2); }
.cuando-icon {
  width:40px; height:40px; flex-shrink:0;
  border-radius:10px; background:var(--sc-soft);
  display:flex; align-items:center; justify-content:center;
  color:var(--sc);
}
.cuando-icon svg { width:20px; height:20px; }
.cuando-text h4 { color:var(--ns-white); margin-bottom:4px; font-size:.95rem; }
.cuando-text p { font-size:.9rem; margin:0; }

/* AEO: each bullet = complete sentence (per brief) */
.cuando-item p { /* already complete sentences in content */ }

/* ════════════════════════════════════
   EL PROCESO — Block 4
   ════════════════════════════════════ */
.proceso { background:#001e2e; }
.proceso-steps {
  display:grid; grid-template-columns:1fr;
  gap:0; margin-top:56px;
  border:1px solid var(--ns-line);
  border-radius:var(--ns-radius-lg); overflow:hidden;
}
.proceso-step {
  display:grid; grid-template-columns:64px 1fr;
  gap:0; border-bottom:1px solid var(--ns-line);
  transition:background .25s;
}
.proceso-step:last-child { border-bottom:none; }
.proceso-step:hover { background:rgba(255,255,255,0.02); }
.proceso-num {
  display:flex; align-items:center; justify-content:center;
  background:var(--sc-soft);
  border-right:1px solid var(--ns-line);
  font-family:'DM Sans',sans-serif; font-size:.75rem;
  font-weight:700; letter-spacing:.15em;
  color:var(--sc); padding:24px 0;
}
.proceso-content { padding:24px 28px; }
.proceso-content h3 {
  font-size:1.05rem; margin-bottom:8px; color:var(--ns-white);
}
.proceso-content p { font-size:.92rem; margin:0; }
/* AEO: include specific timeframes per brief */
.proceso-content .timeframe {
  display:inline-block; font-size:.75rem; font-weight:600;
  letter-spacing:.1em; text-transform:uppercase;
  color:var(--sc); margin-top:8px;
  padding:3px 10px; border-radius:100px;
  background:var(--sc-soft);
}

/* ════════════════════════════════════
   RESULTADOS — Block 5
   ════════════════════════════════════ */
.resultados { background:#001629; }
.ba-grid {
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:20px; margin-top:56px;
}
.ba-card {
  border-radius:var(--ns-radius-lg); overflow:hidden;
  background:var(--ns-surface-1); border:1px solid var(--ns-line);
  transition:border-color .25s;
}
.ba-card:hover { border-color:var(--sc); }
.ba-images {
  display:grid; grid-template-columns:1fr 1fr;
  height:220px; position:relative;
  background:rgba(255,255,255,.03);
}
.ba-images::after {
  content:'ANTES · DESPUÉS';
  position:absolute; top:50%; left:50%;
  transform:translate(-50%,-50%);
  background:rgba(0,0,0,.55); backdrop-filter:blur(4px);
  color:rgba(255,255,255,.6); font-size:.65rem; font-weight:700;
  letter-spacing:.2em; padding:5px 12px; border-radius:100px;
  white-space:nowrap; pointer-events:none;
}
.ba-img {
  background:rgba(255,255,255,.04);
  display:flex; align-items:center; justify-content:center;
  font-size:.7rem; color:rgba(255,255,255,.2);
  letter-spacing:.1em; text-transform:uppercase;
  border-right:1px solid rgba(255,255,255,.04); overflow:hidden;
}
.ba-img:last-child { border-right:none; }
.ba-img img { width:100%; height:100%; object-fit:cover; object-position:center top; }
.ba-body { padding:18px 20px; }
.ba-tag {
  display:inline-block; font-size:.7rem; font-weight:700;
  letter-spacing:.12em; text-transform:uppercase;
  padding:3px 10px; border-radius:100px;
  background:var(--sc-soft); color:var(--sc);
  margin-bottom:8px;
}
.ba-title { font-size:.95rem; font-weight:600; color:var(--ns-white); margin-bottom:4px; }
.ba-meta { font-size:.8rem; color:rgba(255,255,255,.3); }

/* ════════════════════════════════════
   DR. SIERRA EN ESTA INTERVENCIÓN — Block 6 (AEO entity signal)
   ════════════════════════════════════ */
.dr-section {
  background:#001e2e;
  border-top:1px solid var(--ns-line);
  border-bottom:1px solid var(--ns-line);
}
.dr-inner {
  display:grid; grid-template-columns:1fr 1fr;
  gap:clamp(48px,6vw,96px); align-items:center;
}
.dr-stat {
  display:flex; flex-direction:column; gap:4px;
}
.dr-stat-num {
  font-family:'DM Sans',sans-serif; font-size:clamp(2.5rem,5vw,4rem);
  font-weight:700; color:var(--sc); letter-spacing:-.04em; line-height:1;
}
.dr-stat-label {
  font-size:.82rem; color:rgba(255,255,255,.5);
  letter-spacing:.1em; text-transform:uppercase;
}
.dr-stats { display:flex; gap:40px; margin-top:28px; flex-wrap:wrap; padding-top:24px; border-top:1px solid var(--ns-line); }
.dr-quote {
  padding:24px 28px;
  border-radius:var(--ns-radius-lg);
  background:var(--ns-surface-1);
  border:1px solid var(--ns-line);
  border-left:3px solid var(--sc);
  font-size:1.05rem; color:rgba(200,218,235,0.9);
  line-height:1.8; font-style:italic;
}
/* AEO: named entities in this section per brief */
.entity-tag {
  display:inline-flex; align-items:center; gap:6px;
  font-size:.75rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase;
  color:var(--sc); margin-top:16px; margin-right:8px;
  padding:4px 12px; border-radius:100px; background:var(--sc-soft);
}

/* ════════════════════════════════════
   FAQ — Block 7 (AEO critical, per brief)
   H3 = question, P = answer, no nested divs
   ════════════════════════════════════ */
.faq { background:#001629; }
.faq-layout {
  display:grid; grid-template-columns:5fr 7fr;
  gap:clamp(48px,6vw,96px); margin-top:56px; align-items:start;
}
.faq-intro p { font-size:.95rem; line-height:1.8; margin-bottom:24px; }
.faq-list { display:flex; flex-direction:column; gap:12px; }
.faq-item {
  background:rgba(0,20,45,0.75);
  border:1px solid rgba(255,255,255,.08);
  border-left:3px solid transparent;
  border-radius:var(--ns-radius);
  overflow:hidden; backdrop-filter:blur(12px);
  transition:border-color .25s, background .25s;
}
.faq-item[open] {
  border-left-color:var(--sc);
  background:rgba(0,30,60,.7);
}
.faq-item summary {
  list-style:none; cursor:pointer;
  padding:20px 24px;
  display:flex; align-items:center;
  justify-content:space-between; gap:20px;
  font-family:'DM Sans',sans-serif;
  font-size:clamp(1rem,1.3vw,1.15rem);
  font-weight:500; color:var(--ns-white);
  letter-spacing:-.01em;
}
/* AEO: question = H3, answer = P directly after per brief */
.faq-item summary h3 {
  font-size:inherit; font-weight:inherit; color:inherit;
  letter-spacing:inherit; line-height:1.3; margin:0; flex:1;
}
.faq-item[open] summary h3 { color:var(--sc); }
.faq-item summary::-webkit-details-marker { display:none; }
.faq-icon {
  width:24px; height:24px; flex-shrink:0;
  position:relative; border-radius:50%;
  border:1px solid rgba(255,255,255,.2);
}
.faq-icon::before,.faq-icon::after {
  content:''; position:absolute; background:rgba(255,255,255,.6);
  border-radius:2px; transition:transform .3s, opacity .3s;
}
.faq-icon::before { left:5px; right:5px; top:50%; height:1.5px; transform:translateY(-50%); }
.faq-icon::after { top:5px; bottom:5px; left:50%; width:1.5px; transform:translateX(-50%); }
.faq-item[open] .faq-icon { border-color:var(--sc); }
.faq-item[open] .faq-icon::before { background:var(--sc); }
.faq-item[open] .faq-icon::after { transform:translateX(-50%) scaleY(0); }
/* AEO: answer = P directly after summary, no nested divs between h3 and p */
.faq-answer { padding:0 24px 20px; }
.faq-answer p {
  font-size:.95rem; color:rgba(200,218,235,.8); line-height:1.8;
}

/* ════════════════════════════════════
   INTERNAL LINKS — Block 8 (per brief: min 3 named links)
   ════════════════════════════════════ */
.related { background:#001e2e; }
.related-grid {
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:16px;
}
.related-card {
  display:flex; flex-direction:column;
  padding:24px; border-radius:var(--ns-radius-lg);
  background:var(--ns-surface-1); border:1px solid var(--ns-line);
  border-top:2px solid var(--sc-card,var(--ns-line));
  text-decoration:none; color:inherit;
  transition:background .25s, border-color .25s, transform .25s;
}
.related-card:hover {
  background:var(--ns-surface-2); transform:translateY(-2px);
  border-color:var(--sc-card,rgba(255,255,255,.2));
}
.related-card-num {
