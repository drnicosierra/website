---
import Layout from "../layouts/Layout.astro";

const title = 'Cuéntanos tu Caso | Dr. Nico Sierra — Fisura Labiopalatina Barcelona';
const description = 'Cuéntanos tu caso de fisura labiopalatina. El Dr. Nico Sierra revisa personalmente cada consulta y responde en menos de 24 horas. Sin compromiso.';
const canonical = 'https://www.drnicosierra.com/cuentanos-tu-historia/';
const ogTitle = 'Cuéntanos tu Caso | Dr. Nico Sierra Barcelona';
const ogDescription = 'Consulta de fisura labiopalatina con el Dr. Nico Sierra. Respuesta personalizada en menos de 24 horas.';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription}>
  <Fragment slot="head" set:html={`
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
`} />
  <Fragment set:html={`
<main>
<section style="min-height:50vh;background:#001629;display:flex;align-items:flex-end;padding:120px clamp(20px,4vw,48px) 80px;position:relative;">
  <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,18,41,0.9) 0%,rgba(0,18,41,0.7) 100%);"></div>
  <div style="max-width:1200px;margin:0 auto;width:100%;position:relative;z-index:1;">
    <div class="sh">
      <div class="eyebrow" style="color:#4db896;">Contacto</div>
      <h1>Cuéntanos tu historia</h1>
      <p class="lead">El Dr. Sierra revisa personalmente cada caso. Escríbenos con una descripción de tu situación y, si puedes, adjunta algunas fotos. Respondemos en menos de 24 horas.</p>
    </div>
  </div>
</section>
<section class="section" style="background:#001e2e;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(40px,6vw,96px);align-items:start;">
      <!-- Form -->
      <div>
        <h2 style="font-size:1.5rem;margin-bottom:32px;">Envíanos tu caso</h2>
        <!-- Netlify form -->
        <form name="caso-paciente" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/gracias/" style="display:flex;flex-direction:column;gap:20px;">
          <input type="hidden" name="form-name" value="caso-paciente">
          <p style="display:none;"><label>No rellenar: <input name="bot-field"></label></p>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:8px;">Nombre *</label>
            <input type="text" name="nombre" required placeholder="Tu nombre completo" style="width:100%;padding:14px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:'Space Grotesk',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s;" onfocus="this.style.borderColor='rgba(0,131,98,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.12)'">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:8px;">Email *</label>
            <input type="email" name="email" required placeholder="tu@email.com" style="width:100%;padding:14px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:'Space Grotesk',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s;" onfocus="this.style.borderColor='rgba(0,131,98,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.12)'">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:8px;">Teléfono / WhatsApp</label>
            <input type="tel" name="telefono" placeholder="+34 600 000 000" style="width:100%;padding:14px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:'Space Grotesk',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s;" onfocus="this.style.borderColor='rgba(0,131,98,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.12)'">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:8px;">País de residencia</label>
            <input type="text" name="pais" placeholder="España, México, etc." style="width:100%;padding:14px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:'Space Grotesk',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s;" onfocus="this.style.borderColor='rgba(0,131,98,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.12)'">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:8px;">Cuéntanos tu caso *</label>
            <textarea name="caso" required rows="6" placeholder="Describe la situación del paciente: edad, diagnóstico, intervenciones previas, dudas o lo que necesites contarnos..." style="width:100%;padding:14px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#fff;font-family:'Space Grotesk',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s;resize:vertical;" onfocus="this.style.borderColor='rgba(0,131,98,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.12)'"></textarea>
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:8px;">¿Cómo nos encontraste?</label>
            <select name="origen" style="width:100%;padding:14px 18px;background:rgba(0,18,41,0.9);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:rgba(255,255,255,0.7);font-family:'Space Grotesk',sans-serif;font-size:.95rem;outline:none;">
              <option value="">Selecciona una opción</option>
              <option value="google">Búsqueda en Google</option>
              <option value="recomendacion">Recomendación médica</option>
              <option value="familiar">Recomendación familiar o amigo</option>
              <option value="redes">Redes sociales</option>
              <option value="otro">Otro</option>
            </select>
          </div>
          <div style="display:flex;align-items:flex-start;gap:12px;padding:16px;background:rgba(255,255,255,0.03);border-radius:10px;border:1px solid rgba(255,255,255,0.06);">
            <input type="checkbox" name="privacidad" required id="privacidad" style="margin-top:3px;accent-color:#008362;">
            <label for="privacidad" style="font-size:.85rem;color:rgba(255,255,255,0.55);line-height:1.6;">He leído y acepto la <a href="/politica-de-privacidad/" style="color:#4db896;">Política de Privacidad</a>. Consiento el tratamiento de mis datos para gestionar mi consulta.</label>
          </div>
          <button type="submit" class="btn btn-ghost" style="width:100%;justify-content:center;background:rgba(0,131,98,0.15);border-color:rgba(0,131,98,0.4);">Enviar mi caso →</button>
        </form>
      </div>
      <!-- Contact info -->
      <div>
        <div class="sh">
          <div class="eyebrow" style="color:#4db896;">Respuesta garantizada</div>
          <h2>Respondemos en menos de 24 horas.</h2>
          <p>El Dr. Sierra lee personalmente cada mensaje antes de responder. No es una respuesta automática — es una valoración real de tu caso.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:16px;margin-top:8px;">
          <a href="https://wa.me/WHATSAPP_NUMBER" class="btn btn-wa" style="justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zM12 20.5a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5z"/></svg>
            Escríbenos por WhatsApp
          </a>
          <a href="mailto:cuentame@drnicosierra.com" class="btn btn-ghost" style="justify-content:center;">cuentame@drnicosierra.com</a>
        </div>
        <div style="margin-top:40px;padding:24px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;">
          <h3 style="font-size:1rem;margin-bottom:16px;color:#fff;">Pacientes internacionales</h3>
          <p style="font-size:.9rem;">Realizamos valoraciones por telemedicina para familias de fuera de España. Coordinamos la logística del viaje y el seguimiento a distancia.</p>
        </div>
        <div style="margin-top:16px;padding:24px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;">
          <h3 style="font-size:1rem;margin-bottom:16px;color:#fff;">Tus datos están seguros</h3>
          <p style="font-size:.9rem;">Toda la información que compartes es confidencial y se trata de acuerdo con el RGPD. Consulta nuestra <a href="/politica-de-privacidad/" style="color:#4db896;">Política de Privacidad</a>.</p>
        </div>
      </div>
    </div>
  </div>
</section>
</main>
`} />
</Layout>
