---
import Layout from "../layouts/Layout.astro";
import CaseCarousel from '../components/CaseCarousel.astro';
import { getCollection } from 'astro:content';

const title = 'Vidas Transformadas — Resultados Fisura Labiopalatina | Dr. Nico Sierra';
const description = 'Casos reales de cirugía de fisura labiopalatina con el Dr. Nico Sierra. Resultados primarios y de revisión, con consentimiento. Barcelona.';
const canonical = 'https://www.drnicosierra.com/vidas-transformadas/';
const ogTitle = 'Vidas Transformadas | Dr. Nico Sierra Barcelona';
const ogDescription = 'Resultados reales de cirugía de fisura labiopalatina. Casos primarios y de revisión.';

const cases = await getCollection('cases');

// Same card shape the homepage's carousel uses — built from the real cases
// collection instead of curated placeholder data. Same component either way.
const carouselCards = cases.map((c) => {
  const first = c.data.timeline[0];
  const last = c.data.timeline[c.data.timeline.length - 1];
  const displayName = c.data.patientName ?? `Paciente, ${c.data.age}`;
  return {
    media: [
      { src: first.images[0].image, alt: first.images[0].alt, label: first.label },
      { src: last.images[0].image, alt: last.images[0].alt, label: last.label },
    ],
    tag: c.data.condition,
    title: displayName,
    text: c.data.narrative.firstParagraph,
    href: `/vidas-transformadas/${c.data.slug}/`,
  };
});
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription}>
  <section class="section" style="min-height:50vh;background:#001629;display:flex;align-items:flex-end;padding-top:120px;padding-bottom:0;" aria-labelledby="vt-h1">
    <div class="container">
      <div class="sh">
        <div class="eyebrow reveal">Casos reales</div>
        <h1 id="vt-h1" class="reveal rv2">Vidas Transformadas</h1>
        <p class="lead reveal rv3">Casos reales, con consentimiento. Cirugía primaria y de revisión — cada resultado representa un recorrido acompañado de principio a fin por el Dr. Nico Sierra.</p>
      </div>
    </div>
  </section>

  <section class="section" style="background:#001e2e;" aria-labelledby="vt-grid-h2">
    {cases.length > 0 ? (
      <CaseCarousel cards={carouselCards} id="vtCaseCarousel" />
    ) : (
      <div class="container" style="max-width:640px;text-align:center;">
        <div style="padding:80px 40px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:22px;">
          <div class="eyebrow" style="color:#4db896;justify-content:center;margin-bottom:20px;">Próximamente</div>
          <h2 style="margin-bottom:20px;">Los casos están en camino.</h2>
          <p>Estamos preparando la galería de resultados con casos reales y consentimiento de los pacientes. Mientras tanto, puedes contactar directamente con el Dr. Sierra para conocer casos específicos relacionados con tu situación.</p>
          <div style="margin-top:36px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
            <a href="/cuentanos-tu-historia/" class="btn btn-ghost">Cuéntanos tu caso →</a>
          </div>
        </div>
      </div>
    )}
  </section>
</Layout>
