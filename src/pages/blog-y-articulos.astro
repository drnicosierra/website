---
import Layout from "../layouts/Layout.astro";

const title = 'Blog y Artículos sobre Fisura Labiopalatina | Dr. Nico Sierra';
const description = 'Artículos y recursos sobre fisura labiopalatina escritos por el Dr. Nico Sierra. Información para familias, pacientes y profesionales.';
const canonical = 'https://www.drnicosierra.com/blog-y-articulos/';
const ogTitle = 'Blog y Artículos | Dr. Nico Sierra';
const ogDescription = 'Artículos sobre fisura labiopalatina por el Dr. Nico Sierra. Recursos para familias y pacientes.';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription}>
  <Fragment slot="head" set:html={`
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
`} />
  <Fragment set:html={`
<main>
<section style="min-height:40vh;background:#001629;display:flex;align-items:flex-end;padding:120px clamp(20px,4vw,48px) 80px;position:relative;">
  <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,18,41,0.9) 0%,rgba(0,18,41,0.7) 100%);"></div>
  <div style="max-width:1200px;margin:0 auto;width:100%;position:relative;z-index:1;">
    <div class="sh">
      <div class="eyebrow" style="color:#4db896;">Recursos</div>
      <h1>Blog y Artículos</h1>
      <p class="lead">Información clínica y educativa sobre fisura labiopalatina. Escrita por el Dr. Nico Sierra para familias, pacientes y profesionales.</p>
    </div>
  </div>
</section>
<section class="section" style="background:#001e2e;text-align:center;">
  <div class="container" style="max-width:640px;">
    <div style="padding:80px 40px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:22px;">
      <div class="eyebrow" style="color:#4db896;justify-content:center;margin-bottom:20px;">Próximamente</div>
      <h2 style="margin-bottom:20px;">Contenido en preparación.</h2>
      <p>El Dr. Sierra está preparando artículos educativos sobre fisura labiopalatina, técnicas quirúrgicas, cuidados postoperatorios y respuestas a las preguntas más frecuentes. Vuelve pronto.</p>
      <a href="/cuentanos-tu-historia/" class="btn btn-ghost" style="margin-top:36px;display:inline-flex;">¿Tienes una pregunta? Escríbenos →</a>
    </div>
  </div>
</section>
</main>
`} />
</Layout>
