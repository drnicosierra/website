---
import Layout from "../layouts/Layout.astro";
import CaseCarousel from '../components/CaseCarousel.astro';
import { getImage } from 'astro:assets';
import doctorPhotoFile from '../assets/home/doctor-photo.jpg';
import heroPhoto from '../assets/home/hero.jpg';
import { getEntry } from 'astro:content';
import '../styles/home.css';
import dmSans700 from '@fontsource/dm-sans/files/dm-sans-latin-700-normal.woff2?url';

const entry = await getEntry('homepage', 'main');
if (!entry) throw new Error('Missing content entry: homepage/main');
const d = entry.data;

const heroImage = await getImage({
  src: heroPhoto,
  width: 1800, format: 'webp'
});

const doctorPhoto = await getImage({ src: doctorPhotoFile, width: 800, format: 'webp' });

// Native HTML/CSS "care wheel" — 12 specialties around a center hub.
// Positions computed once at build time (no runtime trig / client JS).
// 12 distinct on-brand shades: alternating teal/blue families (Dr. Sierra's
// two brand hues) so every segment reads differently but the ring still
// stays inside the site's own palette instead of a generic rainbow.
const wheelColors = [
  'hsl(163 90% 22%)', 'hsl(205 95% 22%)',
  'hsl(163 85% 30%)', 'hsl(205 90% 30%)',
  'hsl(163 80% 38%)', 'hsl(205 85% 38%)',
  'hsl(163 75% 46%)', 'hsl(205 78% 46%)',
  'hsl(163 65% 54%)', 'hsl(205 70% 54%)',
  'hsl(163 55% 62%)', 'hsl(205 62% 62%)',
];
const wheelItems = [
  // Long labels get a manual <br/> break at a natural word group instead of
  // relying on the browser to wrap them — auto-wrap picks break points that
  // can run wider than a diagonal wedge allows (see width formula below).
  { label: 'Cirugía reconstructiva facial', icon: '<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>' },
  { label: 'Anestesia pediátrica', icon: '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>' },
  { label: 'Enfermería<br/>quirúrgica y<br/>clínica', icon: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>' },
  { label: 'Medicina general', icon: '<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>' },
  { label: 'Estimulación<br/>temprana', icon: '<path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4a2 2 0 0 0 1-1.73z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>' },
  { label: 'Pediatría', icon: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>' },
  { label: 'Educación parental', icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>' },
  { label: 'Atención psicosocial', icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { label: 'Odontología,<br/>ortopedia y<br/>ortodoncia', icon: '<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>' },
  { label: 'Terapia del habla', icon: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>' },
  { label: 'Nutrición y<br/>asesoría en<br/>lactancia', icon: '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>' },
].map((item, i, arr) => {
  const wedgeSize = 360 / arr.length;
  const angleDeg = wedgeSize * i; // item's own center, also used as its position angle
  const angleRad = (angleDeg * Math.PI / 180) - Math.PI / 2;
  const radius = 39; // percent of wheel box — distance of each item's center from the hub
  // A rectangular label sits inside an angular (pie-slice) wedge — the safe
  // horizontal footprint is smallest at 45°/135°/... (diagonal) and largest
  // at 0°/90°/... (cardinal). Narrow diagonal items, keep cardinal ones wide.
  const distFromDiagonal = Math.abs((angleDeg % 90) - 45); // 0 = diagonal, 45 = cardinal
  const cardinalness = distFromDiagonal / 45; // 0..1
  const width = Math.round(112 + cardinalness * 38); // 112px..150px
  return {
    ...item,
    x: (50 + radius * Math.cos(angleRad)).toFixed(2),
    y: (50 + radius * Math.sin(angleRad)).toFixed(2),
    color: wheelColors[i],
    width,
  };
});
// Rotate the whole gradient back by half a wedge so wedge i is centered on
// item i (angleDeg) instead of starting there — keeps every stop at a clean
// non-negative multiple of the wedge size (no negative first-stop edge case).
const wheelWedgeSize = 360 / wheelItems.length;
const wheelRingGradient = `conic-gradient(from ${-(wheelWedgeSize / 2)}deg, ${wheelItems.map((it, i) => `${it.color} ${i * wheelWedgeSize}deg ${(i + 1) * wheelWedgeSize}deg`).join(', ')})`;
function wheelChip(item) {
  return `<span class="ns-wheel__icon" style="--ic:${item.color}"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${item.icon}</svg></span><span class="ns-wheel__label">${item.label}</span>`;
}
// Single source of truth for the hub content — desktop circle and mobile
// banner both render this, so one edit here updates both places.
function wheelHubMarkup(iconSize) {
  return `<span class="ns-wheel-hub__icon"><svg width="${iconSize}" height="${iconSize}" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span><span class="ns-wheel-hub__title">Paciente y familia</span><span class="ns-wheel-hub__subtitle">en el centro del equipo</span>`;
}

const galleryUrls = [
  'https://images.unsplash.com/photo-1555252333-9f8e92e65df9?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1516627145497-ae6968895b74?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1542909168-82c3e7fdca5c?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1499996860823-5214fcc65f8f?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1504257432389-52343af06ae3?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1552058544-f2b08422138a?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1527980965255-d3b416303d12?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1547425260-76bcadfb4f2c?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&h=340&q=80&fit=crop&crop=faces'
];

const ogImageOptimized = await getImage({ src: 'https://images.unsplash.com/photo-1551076805-e1869033e561?w=1200&h=630&q=80&fit=crop', width: 1200, height: 630, format: 'jpg' });
const ogImage = new URL(ogImageOptimized.src, Astro.site).href;

const caseCardMeta = [
  { tag: 'Labio fisurado', title: 'Reconstrucción primaria de labio', text: 'Caso pediátrico — técnica funcional con preservación muscular.' },
  { tag: 'Revisión', title: 'Cirugía de revisión en adulto', text: 'Paciente internacional — corrección de secuelas tras intervención previa.' },
  { tag: 'Paladar hendido', title: 'Cierre de paladar completo', text: 'Paciente pediátrico — cierre del paladar blando y duro en una intervención.' },
  { tag: 'Rinoplastia FLP', title: 'Rinoplastia funcional en FLP', text: 'Adolescente — reconstrucción nasal funcional y estética específica para FLP.' },
  { tag: 'Ortognática', title: 'Cirugía ortognática en FLP', text: 'Adulto joven — corrección de la posición maxilar tras secuelas de fisura.' },
  { tag: 'Encía', title: 'Reconstrucción de encía', text: 'Paciente pediátrico — injerto óseo alveolar previo a erupción del canino definitivo.' },
  { tag: 'Labio fisurado', title: 'Revisión de labio en adulto', text: 'Paciente adulta — corrección de cicatriz y asimetría tras cirugía primaria previa.' },
  { tag: 'NAM', title: 'Ortopedia prequirúrgica NAM', text: 'Recién nacido — moldeado nasoalveolar previo a la cirugía primaria de labio.' },
];

// Homepage shows curated highlights (not yet tied to real case records) —
// vidas-transformadas.astro builds this same shape from the real `cases`
// collection instead. Same component, different data source.
const carouselCards = caseCardMeta.map((meta, i) => ({
  media: [
    { src: galleryUrls[i * 2], alt: `Antes — Caso ${i + 1}`, label: 'Antes' },
    { src: galleryUrls[i * 2 + 1], alt: `Después — Caso ${i + 1}`, label: 'Después' },
  ],
  tag: meta.tag,
  title: meta.title,
  text: meta.text,
}));
---
<Layout title={d.title} description={d.description} canonical={d.canonical} ogTitle={d.ogTitle} ogDescription={d.ogDescription} ogImage={ogImage} keywords={d.keywords}>
  <Fragment slot="head">
    <link rel="preload" as="font" type="font/woff2" href={dmSans700} crossorigin>
  </Fragment>

  <div class="ns-orb ns-orb-1" id="nsOrb1" aria-hidden="true"></div>
  <div class="ns-orb ns-orb-2" id="nsOrb2" aria-hidden="true"></div>

  <header class="ns-scope ns-hero" role="banner">
    <div class="ns-hero__media">
      <img src={heroImage.src} alt="Dr. Nico Sierra — Especialista en fisura labiopalatina">
      <div class="ns-hero__veil" aria-hidden="true"></div>
    </div>
    <div class="ns-hero__watermark" aria-hidden="true">+1.000</div>
    <div class="ns-hero__ticker" aria-hidden="true">
      <div class="ns-hero__ticker-track">
        {[...d.hero.tickerItems, ...d.hero.tickerItems].map((item) => <span>{item}</span>)}
      </div>
    </div>
    <div class="ns-container ns-hero__inner">
      <span class="ns-eyebrow ns-hero__eyebrow ns-hero-anim" style="--d:0ms">{d.hero.eyebrow}</span>
      <h1 class="ns-h1 ns-hero__title ns-hero-anim" style="--d:60ms" set:html={d.hero.h1} />
      <p class="ns-hero__sub ns-hero-anim" style="--d:120ms">{d.hero.lead}</p>
      <div class="ns-hero__ctas ns-hero-anim" style="--d:180ms">
        <a href="/cuentanos-tu-historia" class="ns-btn ns-btn-primary ns-btn-pulse">Cuéntanos tu caso</a>
        <a href={`https://wa.me/${d.whatsappNumber}`} class="btn btn-wa" data-wa-loc="hero" aria-label="Escribir por WhatsApp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zm-8.5 17a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5zm5-6.7c-.3-.1-1.6-.8-1.9-.9s-.4-.1-.6.2-.7.8-.8 1-.3.1-.6 0a7.4 7.4 0 0 1-3.6-3.2c-.3-.5.3-.5.8-1.6.1-.2 0-.4 0-.5l-.9-2.1c-.2-.5-.5-.4-.6-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-1 2.3c0 1.4 1 2.7 1.2 2.9s2 3.1 5 4.3c.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.6-.7 1.9-1.3.2-.7.2-1.2.2-1.3-.1-.2-.3-.3-.6-.4z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
    <a href="#ns-about-title" class="ns-hero__scroll" aria-label="Continuar"><span></span></a>
  </header>

  <section class="ns-scope ns-section ns-about ns-section-teal" aria-labelledby="ns-about-title">
    <div class="ns-container">
      <div class="ns-about__top">
        <figure class="ns-about__media ns-reveal">
          <img src={doctorPhoto.src} alt="Dr. Nico Sierra — Especialista en fisura labiopalatina" loading="lazy">
          <div class="ns-about__media-mark" aria-hidden="true"></div>
        </figure>
        <div class="ns-about__text">
          <div class="ns-sh">
            <span class="ns-eyebrow">{d.about.eyebrow}</span>
            <h2 id="ns-about-title" class="ns-h2 ns-about__title ns-reveal">{d.about.h2}</h2>
          </div>
          <div class="ns-about__body ns-reveal">
            {d.about.paragraphs.map((p) => <p>{p}</p>)}
          </div>
        </div>
      </div>
      <div class="ns-about__bottom ns-reveal">
        <ul class="ns-about__creds ns-about__creds--5" role="list">
          {d.about.credentials.map((c) => (
            <li class="ns-cred">
              <div class="ns-cred__icon" style={`--ci:${c.color}`} set:html={`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${c.iconSvg}</svg>`} />
              <div><strong>{c.title}</strong><span>{c.text}</span></div>
            </li>
          ))}
        </ul>
        <a href={d.about.ctaHref} class="ns-btn ns-btn-outline ns-about__cta">{d.about.ctaLabel}</a>
      </div>
    </div>
  </section>

  <section class="ns-scope ns-section ns-timeline" aria-labelledby="ns-timeline-title">
    <div class="ns-container">
      <header class="ns-timeline__head ns-reveal ns-sh ns-sh--center">
        <span class="ns-eyebrow">{d.timeline.eyebrow}</span>
        <h2 id="ns-timeline-title" class="ns-h2" set:html={d.timeline.h2} />
        <p class="ns-lead" style="max-width:52ch;">{d.timeline.lead}</p>
      </header>
      <figure class="ns-wheel-figure ns-reveal" aria-label="Especialidades del equipo que acompaña el tratamiento de la fisura labiopalatina">
        <span class="ns-eyebrow">Equipo multidisciplinario</span>

        {/* Desktop/tablet — true wheel, shown only once it comfortably fits (≥900px) */}
        <div class="ns-wheel-scroll">
          <div class="ns-wheel-frame">
            <div class="ns-wheel" style={`--wr-bg:${wheelRingGradient}`}>
              <div class="ns-wheel__ring" aria-hidden="true"></div>
              <div class="ns-wheel__hub" set:html={wheelHubMarkup(32)} />
              <ul class="ns-wheel__ring-items" role="list">
                {wheelItems.map((item) => (
                  <li class="ns-wheel__item" style={`left:${item.x}%;top:${item.y}%;width:${item.width}px;`} set:html={wheelChip(item)} />
                ))}
              </ul>
            </div>
          </div>
        </div>

        {/* Mobile/small-tablet — a wheel can't stay readable this narrow, so
            the same 11 specialties become a highlighted hub + card grid. */}
        <div class="ns-wheel-mobile">
          <div class="ns-wheel-mobile__hub" set:html={wheelHubMarkup(28)} />
          <ul class="ns-wheel-mobile__grid" role="list">
            {wheelItems.map((item) => (
              <li class="ns-wheel-mobile__item" style={`--ic:${item.color};`} set:html={wheelChip(item)} />
            ))}
          </ul>
        </div>
      </figure>
      <div class="ns-tl" id="nsTl" aria-label="Recorrido del paciente FLP">
        <svg class="ns-tl__line-svg" aria-hidden="true" preserveAspectRatio="none">
          <path class="ns-tl__line-path" id="nsTlPath" d=""/>
        </svg>
        <div class="ns-tl__nodes">
          {d.timeline.nodes.map((node, i) => (
            <div class={`ns-tl__node ns-reveal ${i === d.timeline.nodes.length - 1 ? 'ns-tl__node--open' : ''}`} style={`--sc:${node.color}`} data-href={node.href}>
              <div class="ns-tl__node-dot" set:html={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">${node.iconSvg}</svg>`} />
              <div class="ns-tl__node-content">
                <span class="ns-tl__node-num">{node.num}</span>
                <h3 class="ns-tl__node-name" set:html={node.name} />
                <p>{node.text}</p>
                <a href={node.href} class={`ns-tl__node-link ${i === d.timeline.nodes.length - 1 ? 'ns-tl__node-link--cta' : ''}`}>{i === d.timeline.nodes.length - 1 ? 'Escríbenos →' : 'Ver →'}</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
  (function(){
    var tl = document.getElementById('nsTl');
    if(!tl) return;
    if('IntersectionObserver' in window){
      var tlObs = new IntersectionObserver(function(entries){
        if(entries[0].isIntersecting){ tl.classList.add('is-drawing'); tlObs.disconnect(); }
      },{threshold:.3});
      tlObs.observe(tl);
    }
    tl.querySelectorAll('.ns-tl__node').forEach(function(n){
      n.addEventListener('click', function(){
        var href = n.getAttribute('data-href');
        if(href) window.location.href = href;
      });
    });
  })();
  </script>

  <section class="ns-scope ns-section ns-services ns-section-mid" aria-labelledby="ns-services-title">
    <div class="ns-container">
      <header class="ns-services__head ns-reveal">
        <span class="ns-eyebrow">{d.careTimeline.eyebrow}</span>
        <h2 id="ns-services-title" class="ns-h2" set:html={d.careTimeline.h2} />
        {d.careTimeline.lead.split('\n\n').map((para) => (
          <p class="ns-lead" style="margin-top:18px;">{para}</p>
        ))}
        <h3 class="ns-h3">{d.careTimeline.timelineTitle}</h3>
        <p class="ns-care-methodology">{d.careTimeline.methodologyNote}</p>
      </header>
      <div class="ns-care-legend ns-reveal">
        <span class="ns-care-legend__item"><span class="ns-care-legend__swatch ns-care-legend__swatch--treatment"></span>{d.careTimeline.legendTreatment}</span>
        <span class="ns-care-legend__item"><span class="ns-care-legend__swatch ns-care-legend__swatch--coordinated"></span>{d.careTimeline.legendCoordinated}</span>
      </div>
    </div>
    <div class="ns-care-scroll-wrap">
      <div class="ns-care-fade-left" aria-hidden="true"></div>
      <div class="ns-care-scroll">
        <div class="ns-care-grid" style={`grid-template-columns:repeat(${d.careTimeline.columns.length},minmax(var(--ns-care-col-min,54px),1fr));grid-template-rows:auto repeat(${d.careTimeline.rows.length},var(--ns-care-row-h,44px));`}>
          {d.careTimeline.columns.map((col, i) => (
            <div class="ns-care-col-head" style={`grid-column:${i + 1};grid-row:1;`} set:html={col} />
          ))}
          {d.careTimeline.rows.map((row, i) =>
            row.type === 'treatment' ? (
              <a href={row.href} class="ns-care-bar ns-care-bar--treatment" style={`grid-column:${row.startCol} / ${row.endCol};grid-row:${i + 2};--sc:${row.color};`}>
                {row.label}
              </a>
            ) : (
              <div class="ns-care-bar ns-care-bar--coordinated" style={`grid-column:${row.startCol} / ${row.endCol};grid-row:${i + 2};`}>
                {row.label}
              </div>
            )
          )}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
  (function(){
    var scroller = document.querySelector('.ns-care-scroll');
    var wrap = document.querySelector('.ns-care-scroll-wrap');
    if(!scroller || !wrap) return;
    var raf = null;
    var idleTimer = null;
    function apply(){
      var gap = scroller.scrollWidth - scroller.clientWidth - scroller.scrollLeft;
      var scrollable = scroller.scrollWidth > scroller.clientWidth + 1;
      wrap.classList.toggle('is-scrollable', scrollable);
      wrap.classList.toggle('at-end', gap <= 4);
      wrap.classList.toggle('at-start', scroller.scrollLeft <= 4);
    }
    function onScroll(){
      wrap.classList.add('scrolling');
      if (idleTimer) clearTimeout(idleTimer);
      idleTimer = setTimeout(function(){
        wrap.classList.remove('scrolling');
        apply();
      }, 500);
      if (raf) return;
      raf = requestAnimationFrame(function(){ raf = null; apply(); });
    }
    scroller.addEventListener('scroll', onScroll, { passive:true });
    window.addEventListener('resize', apply);
    apply();
  })();
  </script>

  <section class="ns-scope ns-section ns-journey ns-section-green" aria-labelledby="ns-journey-title">
    <div class="ns-container ns-journey__layout">
      <div class="ns-journey__left ns-reveal">
        <span class="ns-eyebrow">{d.journey.eyebrow}</span>
        <h2 id="ns-journey-title" class="ns-h2" set:html={d.journey.h2} />
        <p style="color:rgba(255,255,255,0.65);font-size:1rem;line-height:1.75;max-width:32ch;margin-top:16px;">{d.journey.lead}</p>
        <a href={d.journey.ctaHref} class="ns-btn ns-btn-ghost" style="display:inline-flex;margin-top:40px;border-color:rgba(255,255,255,0.35);">{d.journey.ctaLabel}</a>
      </div>
      <ol class="ns-journey__steps" role="list">
        {d.journey.steps.map((step, i) => (
          <li class="ns-journey__step ns-reveal">
            <div class={`ns-journey__line ${i === d.journey.steps.length - 1 ? 'ns-journey__line--last' : ''}`} aria-hidden="true"></div>
            <div class={`ns-journey__node ${i === d.journey.steps.length - 1 ? 'ns-journey__node--last' : ''}`}><span>{step.num}</span></div>
            <div class="ns-journey__content">
              <h3 class="ns-h4">{step.title}</h3>
              <p>{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="ns-scope ns-section ns-section-dark ns-results" aria-labelledby="ns-results-title">
    <div class="ns-container">
      <header class="ns-results__head ns-reveal">
        <span class="ns-eyebrow">{d.results.eyebrow}</span>
        <h2 id="ns-results-title" class="ns-h2">{d.results.h2}</h2>
        <p class="ns-lead">{d.results.lead}</p>
      </header>
    </div>
    <CaseCarousel cards={carouselCards} id="homeCaseCarousel" />
    <div class="ns-container">
      <a href={d.results.ctaHref} class="ns-btn ns-btn-ghost ns-results__cta">{d.results.ctaLabel}</a>
    </div>
  </section>

  <section class="ns-scope ns-section ns-testimonials ns-section-teal" aria-labelledby="ns-testim-title">
    <div class="ns-container">
      <header class="ns-testimonials__head ns-reveal">
        <span class="ns-eyebrow">{d.testimonials.eyebrow}</span>
        <h2 id="ns-testim-title" class="ns-h2">{d.testimonials.h2}</h2>
      </header>
      <div class="ns-testimonials__grid">
        {d.testimonials.quotes.map((q) => (
          <figure class="ns-quote ns-reveal">
            <svg class="ns-quote__mark" width="34" height="28" viewBox="0 0 34 28" aria-hidden="true"><path fill="currentColor" d="M0 28V16C0 7.2 5.7 1.6 14 0v6c-4.3 1-7 4-7 8h7v14H0zm20 0V16c0-8.8 5.7-14.4 14-16v6c-4.3 1-7 4-7 8h7v14H20z"/></svg>
            <blockquote>{q.text}</blockquote>
            <figcaption><strong>{q.name}</strong><span>{q.role}</span></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="ns-scope ns-section ns-faq ns-section-deep" aria-labelledby="ns-faq-title">
    <div class="ns-container ns-faq__inner">
      <header class="ns-faq__head ns-reveal">
        <span class="ns-eyebrow">Preguntas frecuentes</span>
        <h2 id="ns-faq-title" class="ns-h2">Lo que toda familia quiere saber.</h2>
      </header>
      <div class="ns-faq__list">
        {d.faq.map((item) => (
          <details class="ns-faq__item ns-reveal">
            <summary><span>{item.question}</span><i aria-hidden="true"></i></summary>
            <div class="ns-faq__answer"><p>{item.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="ns-scope ns-cta-banner" aria-labelledby="ns-cta-title">
    <div class="ns-container ns-cta-banner__inner">
      <div class="ns-cta-banner__text ns-reveal">
        <span class="ns-eyebrow">{d.ctaBanner.eyebrow}</span>
        <h2 id="ns-cta-title" class="ns-h2">{d.ctaBanner.h2}</h2>
        <p class="ns-lead">{d.ctaBanner.lead}</p>
      </div>
      <div class="ns-cta-banner__actions ns-reveal">
        <a href={`https://wa.me/${d.whatsappNumber}`} class="ns-btn ns-btn-whatsapp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zM12 20.5a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5z"/></svg>
          {d.ctaBanner.whatsappLabel}
        </a>
        <a href={d.ctaBanner.formHref} class="ns-btn ns-btn-outline" style="border-color:var(--ns-white);color:#fff;">{d.ctaBanner.formLabel}</a>
      </div>
    </div>
  </section>

  <div class="ns-signature ns-scope" aria-hidden="true">
    <div class="ns-signature__name">{d.signature.name}</div>
    <div class="ns-signature__line">{d.signature.line}</div>
  </div>

  <script is:inline>
  (function(){
    var nav = document.getElementById('nsNav');
    if (nav){
      var onScroll = function(){
        if (window.scrollY > 24) nav.classList.add('is-scrolled');
        else nav.classList.remove('is-scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive:true });
      onScroll();
    }
    var burger = document.getElementById('nsBurger');
    var menu = document.getElementById('nsMobileMenu');
    if (burger && menu){
      burger.addEventListener('click', function(){
        var open = menu.getAttribute('data-open') === 'true';
        menu.setAttribute('data-open', String(!open));
        menu.hidden = open;
        burger.setAttribute('aria-expanded', String(!open));
      });
    }
    var reveals = document.querySelectorAll('.ns-reveal');
    var trustItems = document.querySelectorAll('.ns-trust__item');
    if ('IntersectionObserver' in window && reveals.length){
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(en){
          if (en.isIntersecting){ en.target.classList.add('is-visible'); io.unobserve(en.target); }
        });
      }, { threshold:0.12, rootMargin:'0px 0px -40px 0px' });
      reveals.forEach(function(el){ io.observe(el); });
      var tObs=new IntersectionObserver(function(ee){ee.forEach(function(e){if(e.isIntersecting){e.target.classList.add('is-visible');tObs.unobserve(e.target);}});},{threshold:.2});
      trustItems.forEach(function(el){tObs.observe(el);});
    } else {
      reveals.forEach(function(el){ el.classList.add('is-visible'); });
    }
    var counters = document.querySelectorAll('[data-counter]');
    if ('IntersectionObserver' in window && counters.length){
      var cio = new IntersectionObserver(function(entries){
        entries.forEach(function(en){
          if (!en.isIntersecting) return;
          var el = en.target;
          var target = parseInt(el.getAttribute('data-counter'), 10) || 0;
          if (target <= 0) { cio.unobserve(el); return; }
          var dur = 1600, start = performance.now();
          var suffix = el.querySelector('span') ? el.querySelector('span').outerHTML : '';
          function tick(now){
            var p = Math.min(1, (now - start) / dur);
            var eased = 1 - Math.pow(1 - p, 3);
            var val = Math.floor(target * eased);
            el.innerHTML = val.toLocaleString('es-ES') + suffix;
            if (p < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
          cio.unobserve(el);
        });
      }, { threshold:0.4 });
      counters.forEach(function(el){ cio.observe(el); });
    }
    var y = document.getElementById('nsYear');
    if (y) y.textContent = new Date().getFullYear();
    var orb1 = document.getElementById('nsOrb1');
    var orb2 = document.getElementById('nsOrb2');
    if(orb1 && orb2){
      var ticking = false;
      window.addEventListener('scroll', function(){
        if(!ticking){
          requestAnimationFrame(function(){
            var p = window.scrollY / (document.body.scrollHeight - window.innerHeight);
            var vh = window.innerHeight / 100;
            var vw = window.innerWidth / 100;
            orb1.style.transform = 'translate3d(' + (30 * p * vw) + 'px,' + (60 * p * vh - 2 * vh) + 'px,0)';
            orb2.style.transform = 'translate3d(' + (-20 * p * vw) + 'px,' + (10 * vh - 40 * p * vh) + 'px,0)';
            ticking = false;
          });
          ticking = true;
        }
      }, {passive:true});
    }
  })();
  </script>
</Layout>
