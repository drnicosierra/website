<script>
(function(){
  var list = document.getElementById('nsSvcList');
  var bg = document.getElementById('nsSvcBg');
  var bgImg = document.getElementById('nsSvcBgImg');
  if(!list||!bg||!bgImg) return;
  var rows = list.querySelectorAll('.ns-svc-row');
  var hideTimer;
  rows.forEach(function(row){
    row.addEventListener('mouseenter', function(){
      clearTimeout(hideTimer);
      var img = row.getAttribute('data-img');
      if(img && bgImg.src !== img){
        bgImg.style.opacity='0';
        setTimeout(function(){
          bgImg.src = img;
          bgImg.style.opacity='1';
        }, 150);
      }
      bg.classList.add('is-visible');
      row.classList.add('is-hovered');
    });
    row.addEventListener('mouseleave', function(){
      row.classList.remove('is-hovered');
      hideTimer = setTimeout(function(){ bg.classList.remove('is-visible'); }, 300);
    });
  });
})();
</script>

