---
import Layout from "../layouts/Layout.astro";

const title = 'Dr. Nico Sierra — Especialista en Fisura Labiopalatina | Barcelona';
const description = 'Dr. Nico Sierra, cirujano dedicado exclusivamente a la fisura labiopalatina en Barcelona. Reconstrucción de labio fisurado, paladar hendido y cirugía de revisión para pacientes nacionales e internacionales.';
const canonical = 'https://www.drnicosierra.com/';
const ogTitle = 'Dr. Nico Sierra — Especialista en Fisura Labiopalatina';
const ogDescription = 'Atención quirúrgica integral para fisura labiopalatina. Una práctica dedicada, en Barcelona, para familias de toda España y el extranjero.';
const ogImage = 'https://images.unsplash.com/photo-1551076805-e1869033e561?w=1800&q=85&fit=crop';
const keywords = 'fisura labiopalatina, labio fisurado, paladar hendido, FLP, cirugía de revisión, Dr. Nico Sierra, cirujano Barcelona, NAM, ortognática FLP, rinoplastia FLP';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription} ogImage={ogImage} keywords={keywords}>
  <Fragment slot="head" set:html={`
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  /* --- Tokens ---------------------------------------------------------- */
  :root{
    --ns-blue-900:#001829;     /* deepest — hero base */
    --ns-blue-800:#001e3a;     /* deep navy */
    --ns-blue-700:#002d52;     /* mid-dark */
    --ns-blue-600:#003a63;     /* upper-mid */
    --ns-blue-500:#005085;     /* brand primary */
    --ns-blue-400:#0d74c4;     /* interactive / CTA */
    --ns-teal-600:#008362;     /* accent — warmth */
    --ns-teal-300:#4db896;     /* lighter teal for text on dark */
    --ns-teal-glow:rgba(0,131,98,0.18);

    --ns-ink:#e8edf2;          /* primary text on dark */
    --ns-ink-soft:rgba(200,218,235,0.75); /* secondary text on dark */
    --ns-mute:rgba(160,185,210,0.5);
    --ns-line:rgba(255,255,255,0.08);     /* hairlines on dark */
    --ns-surface-1:rgba(255,255,255,0.04);  /* card bg */
    --ns-surface-2:rgba(255,255,255,0.07);  /* elevated card bg */
    --ns-white:#ffffff;
    --ns-whatsapp:#25D366;

    --ns-radius:14px;
    --ns-radius-lg:22px;
    --ns-shadow-sm:0 2px 12px rgba(0,0,0,0.2);
    --ns-shadow-md:0 8px 40px rgba(0,0,0,0.35);
    --ns-ease:cubic-bezier(.22,.61,.36,1);
    --ns-container:1240px;
  }

  /* --- Reset (scoped softly) ------------------------------------------- */
  .ns-scope, .ns-scope *, .ns-scope *::before, .ns-scope *::after{
    box-sizing:border-box;
  }
  .ns-scope img{max-width:100%;display:block;height:auto;}
  .ns-scope a{color:inherit;text-decoration:none;}
  .ns-scope button{font:inherit;cursor:pointer;border:0;background:none;color:inherit;}

  /* --- Typography ------------------------------------------------------- */
  .ns-scope{
    font-family:'Space Grotesk',system-ui,sans-serif;
    color:var(--ns-ink);
    background:transparent;
    -webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;
    line-height:1.6;
  }
  .ns-h1,.ns-h2,.ns-h3,.ns-h4{
    font-family:'DM Sans',system-ui,sans-serif;
    color:var(--ns-white);
    letter-spacing:-.02em;
    line-height:1.08;
    font-weight:500;
    margin:0;
  }
  .ns-h1{font-size:clamp(2.6rem,6vw,5rem);letter-spacing:-.035em;}
  .ns-h2{font-size:clamp(2rem,3.6vw,3.2rem);letter-spacing:-.025em;}
  .ns-h3{font-size:clamp(1.35rem,1.8vw,1.65rem);letter-spacing:-.015em;font-weight:500;}
  .ns-h4{font-size:1.05rem;font-weight:500;letter-spacing:-.005em;}
  .ns-eyebrow{
    font-family:'Space Grotesk',sans-serif;
    font-size:.72rem;font-weight:600;
    letter-spacing:.22em;text-transform:uppercase;
    color:var(--ns-teal-600);
    display:inline-flex;align-items:center;gap:.6rem;
    margin-bottom:0;
  }
  .ns-eyebrow::before{
    content:"";width:28px;height:2px;background:var(--ns-teal-600);border-radius:2px;
  }
  .ns-lead{font-size:1.05rem;color:var(--ns-ink-soft);max-width:60ch;line-height:1.8;margin:0;}

  /* ── SECTION HEADER BLOCK (.ns-sh) ──
     Wrap .ns-eyebrow + .ns-h2 + .ns-lead in .ns-sh.
     Single source of truth for all section header spacing.
     eyebrow → h2: 12px | h2 → lead: 16px | header → content: 40px
  */
  .ns-sh{margin-bottom:40px;}
  .ns-sh--center{text-align:center;}
  .ns-sh--center .ns-eyebrow{justify-content:center;}
  .ns-sh * + .ns-h1,
  .ns-sh * + .ns-h2,
  .ns-sh * + .ns-h3{margin-top:12px;}
  .ns-sh .ns-h2 + p,  .ns-sh .ns-h2 + .ns-lead,
  .ns-sh .ns-h1 + p,  .ns-sh .ns-h1 + .ns-lead,
  .ns-sh .ns-h3 + p{margin-top:16px;}
  .ns-sh + p, .ns-sh + .ns-lead{margin-top:16px;}
  .ns-sh p, .ns-sh .ns-lead{margin-top:0;}
  /* h2/h3/h4 self-margins reset */
  .ns-h1,.ns-h2,.ns-h3,.ns-h4{margin:0;}
  .ns-h2 + p, .ns-h2 + .ns-lead{margin-top:16px;}
  .ns-h3 + p{margin-top:8px;}
  .ns-h4 + p{margin-top:4px;}
  p + p{margin-top:16px;}

  /* --- Layout helpers --------------------------------------------------- */
  .ns-container{max-width:var(--ns-container);margin:0 auto;padding:0 24px;}
  .ns-section{padding:clamp(72px,9vw,128px) 0;}
  .ns-section-dark{background:var(--ns-blue-800);color:var(--ns-white);}
  .ns-section-dark .ns-h2,
  .ns-section-dark .ns-h3,
  .ns-section-dark .ns-h4{color:var(--ns-white);}
  .ns-section-dark .ns-eyebrow{color:#7fd0b3;}
  .ns-section-dark .ns-eyebrow::before{background:#7fd0b3;}
  .ns-section-dark .ns-lead{color:rgba(255,255,255,.78);}

  /* --- Buttons ---------------------------------------------------------- */
  .ns-btn{
    display:inline-flex;align-items:center;justify-content:center;gap:.6rem;
    padding:16px 28px;border-radius:999px;
    font-family:'DM Sans',sans-serif;font-weight:500;font-size:.98rem;
    letter-spacing:-.005em;
    transition:transform .25s var(--ns-ease), background .25s var(--ns-ease), color .25s var(--ns-ease), box-shadow .25s var(--ns-ease);
    will-change:transform;
  }
  .ns-btn-primary{background:var(--ns-blue-500);color:var(--ns-white);box-shadow:0 8px 22px rgba(13,116,196,.28);}
  .ns-btn-primary:hover{background:var(--ns-blue-800);transform:translateY(-1px);box-shadow:0 12px 28px rgba(0,80,133,.32);}
  .ns-btn-ghost{background:transparent;color:var(--ns-white);border:1px solid rgba(255,255,255,.55);}
  .ns-btn-ghost:hover{background:rgba(255,255,255,.1);border-color:#fff;}
  .ns-btn-outline{background:transparent;color:var(--ns-white);border:1px solid rgba(255,255,255,0.45);}
  .ns-btn-outline:hover{background:rgba(255,255,255,0.1);border-color:var(--ns-white);}
  .ns-btn-whatsapp{background:var(--ns-whatsapp);color:#fff;}
  .ns-btn-whatsapp:hover{background:#1ebe5a;transform:translateY(-1px);}

  /* --- Scroll reveal ---------------------------------------------------- */
  .ns-reveal{opacity:0;transform:translateY(22px);transition:opacity .8s var(--ns-ease) var(--rv,0ms), transform .8s var(--ns-ease) var(--rv,0ms);}
  .ns-reveal.is-visible{opacity:1;transform:none;}
  .ns-about__media.ns-reveal{transform:scale(0.97);}
  .ns-about__media.ns-reveal.is-visible{transform:scale(1);}
  .ns-svc-row:nth-child(2){--rv:60ms}.ns-svc-row:nth-child(3){--rv:120ms}.ns-svc-row:nth-child(4){--rv:180ms}
  .ns-svc-row:nth-child(5){--rv:240ms}.ns-svc-row:nth-child(6){--rv:300ms}.ns-svc-row:nth-child(7){--rv:360ms}.ns-svc-row:nth-child(8){--rv:420ms}
  .ns-journey__step:nth-child(2){--rv:120ms}.ns-journey__step:nth-child(3){--rv:240ms}.ns-journey__step:nth-child(4){--rv:360ms}
  .ns-testimonials__grid .ns-reveal:nth-child(2){--rv:140ms}.ns-testimonials__grid .ns-reveal:nth-child(3){--rv:280ms}

  /* --- Focus ------------------------------------------------------------ */
  .ns-scope :focus-visible{outline:2px solid var(--ns-blue-500);outline-offset:3px;border-radius:6px;}

  /* --- Selection -------------------------------------------------------- */
  .ns-scope ::selection{background:var(--ns-blue-500);color:#fff;}


  /* ── SECTION COLOR PERSONALITIES ─────────────────────────────── */
  .ns-section-teal {
    background: #002a22;
    position:relative;
  }

  .ns-section-mid {
    background: #002236;
  }

  .ns-section-deep {
    background: #00111e;
  }

  /* Full green section — the most distinctive moment on the page */
  .ns-section-green {
    background: #006b50;
    border-top:1px solid rgba(255,255,255,0.08);
    border-bottom:1px solid rgba(0,0,0,0.15);
  }
  .ns-section-green .ns-h2,
  .ns-section-green .ns-h3,
  .ns-section-green .ns-h4 { color:#fff; }
  .ns-section-green .ns-eyebrow { color:rgba(180,240,220,0.85); }
  .ns-section-green .ns-eyebrow::before { background:rgba(180,240,220,0.85); }
  .ns-section-green .ns-journey__node {
    background:rgba(255,255,255,0.12) !important;
    border-color:rgba(255,255,255,0.25) !important;
    color:#fff !important;
  }
  .ns-section-green .ns-journey__step:nth-child(even) .ns-journey__node {
    background:rgba(255,255,255,0.22) !important;
    border-color:rgba(255,255,255,0.4) !important;
  }
  .ns-section-green .ns-journey__step h3 { color:#fff; }
  .ns-section-green .ns-journey__step p { color:rgba(255,255,255,0.75); }
  .ns-section-green .ns-journey__steps::before {
    background:rgba(255,255,255,0.2);
  }

  /* Trust strip & results keep their own dark */
  .ns-trust {
    background:
      radial-gradient(ellipse 100% 150% at 50% -20%, rgba(13,116,196,0.25) 0%, transparent 60%),
      rgba(0,15,35,0.75) !important;
  }

  /* ── SUBTLE BORDER GLOW on teal sections ─────────────────────── */
  .ns-section-teal::before {
    content:'';
    position:absolute; inset:0; z-index:0; pointer-events:none;
    border-top:1px solid rgba(0,131,98,0.3);
    border-bottom:1px solid rgba(0,131,98,0.2);
  }
  .ns-section-teal > * { position:relative; z-index:1; }

  /* ── SCROLL FADE BETWEEN SECTIONS ───────────────────────────── */
  .ns-scope.ns-section {
    position:relative;
  }
  /* Subtle top fade for visual separation without hard lines */
  .ns-section-mid::after,
  .ns-section-deep::after {
    content:'';
    position:absolute;bottom:0;left:0;right:0;
    height:80px;
    background:linear-gradient(to bottom, transparent, rgba(0,10,20,0.3));
    pointer-events:none;
    z-index:0;
  }

  /* ── ORBS — more varied colors ─────────────────────────────────── */
  .ns-orb-1 {
    width:1000px; height:1000px;
    background:radial-gradient(circle, rgba(0,80,140,0.08) 0%, transparent 70%);
    filter:blur(80px);
  }
  .ns-orb-2 {
    width:800px; height:800px;
    background:radial-gradient(circle, rgba(0,100,80,0.09) 0%, transparent 70%);
    filter:blur(80px);
  }

  /* Testimonial cards on teal bg */
  .ns-section-teal .ns-quote {
    background:rgba(0,15,35,0.55) !important;
    border-color:rgba(255,255,255,0.1) !important;
    backdrop-filter:blur(16px);
  }
  .ns-section-teal .ns-quote blockquote { color:rgba(220,235,248,0.9); }

  @media (prefers-reduced-motion:reduce){
    .ns-reveal{opacity:1;transform:none;transition:none;}
    .ns-btn{transition:none;}
    .ns-section-teal::before{animation:none;}
  }
</style>
`} />
  <Fragment set:html={`
<!-- ============================================================================
  GLOBAL DARK BACKGROUND — gradient narrative + breathing light orb
  This goes on the <body> or a full-page wrapper in Webflow
============================================================================ -->
<style>
  /* Fixed gradient narrative — dark top, slightly warmer mid, deep at bottom */
  body, .ns-page-bg {
    background: #001e2e;
    min-height:100vh;
  }

  /* All sections transparent so gradient shows through */
  .ns-scope.ns-section,
  .ns-scope.ns-section-dark,
  section.ns-scope {
    background: transparent !important;
  }

  /* Eyebrow + lead on dark background */
  .ns-eyebrow { color: var(--ns-teal-300); }
  .ns-eyebrow::before { background: var(--ns-teal-300); }
  .ns-lead { color: var(--ns-ink-soft); }

  /* Section dividers — subtle hairline instead of background change */
  .ns-scope.ns-section + .ns-scope.ns-section {
    border-top: 1px solid var(--ns-line);
  }

  /* Breathing light orb — follows scroll via JS class */
  .ns-orb {
    position:fixed;
    pointer-events:none;
    z-index:0;
    border-radius:50%;
    filter:blur(120px);
    transition:top 1.2s var(--ns-ease), left 1.2s var(--ns-ease), opacity 1.2s ease;
    will-change:top,left;
  }
  .ns-orb-1 {
    width:700px; height:700px;
    background:radial-gradient(circle, rgba(13,116,196,0.18) 0%, transparent 70%);
    top:10vh; left:-10vw;
  }
  .ns-orb-2 {
    width:500px; height:500px;
    background:radial-gradient(circle, rgba(0,131,98,0.14) 0%, transparent 70%);
    top:60vh; right:-5vw;
  }
</style>

<!-- Orb elements — inject once, outside sections -->
<div class="ns-orb ns-orb-1" id="nsOrb1" aria-hidden="true"></div>
<div class="ns-orb ns-orb-2" id="nsOrb2" aria-hidden="true"></div>





<!-- ============================================================================
  BLOCK 4 — HERO
  Paste into: Webflow Embed (first section under navbar)
============================================================================ -->
<header class="ns-scope ns-hero" role="banner">
  <div class="ns-hero__media">
    <img src="https://images.unsplash.com/photo-1551076805-e1869033e561?w=1800&q=85&fit=crop" alt="Dr. Nico Sierra — Especialista en fisura labiopalatina">
    <div class="ns-hero__veil" aria-hidden="true"></div>
  </div>

  <!-- Watermark number — bottom right -->
  <div class="ns-hero__watermark" aria-hidden="true">+1.000</div>

  <!-- Vertical ticker — right edge -->
  <div class="ns-hero__ticker" aria-hidden="true">
    <div class="ns-hero__ticker-track">
      <span>Fisura labiopalatina</span><span>Barcelona · España</span>
      <span>Labio fisurado</span><span>Paladar hendido</span>
      <span>Cirugía de revisión</span><span>Operation Smile</span>
      <span>Smile Train</span><span>Pacientes internacionales</span>
      <span>Fisura labiopalatina</span><span>Barcelona · España</span>
      <span>Labio fisurado</span><span>Paladar hendido</span>
    </div>
  </div>

  <div class="ns-container ns-hero__inner">
    <span class="ns-eyebrow ns-hero__eyebrow ns-hero-anim" style="--d:0ms">Especialista en fisura labiopalatina (labio y paladar hendido). Barcelona</span>
    <h1 class="ns-h1 ns-hero__title ns-hero-anim" style="--d:120ms">
      Una práctica dedicada<br>
      <em>en exclusiva</em> a la fisura labiopalatina.
    </h1>
    <p class="ns-hero__sub ns-hero-anim" style="--d:260ms">
      Atención quirúrgica altamente especializada en todas las etapas del desarrollo — desde el diagnóstico prenatal hasta la cirugía de revisión en la edad adulta. Casos primarios, secuelas complejas y familias de toda España y Europa.
    </p>

    <div class="ns-hero__ctas ns-hero-anim" style="--d:380ms">
      <a href="/cuentanos-tu-historia" class="ns-btn ns-btn-primary ns-btn-pulse">Cuéntanos tu caso</a>
      <a href="https://wa.me/WHATSAPP_NUMBER" class="ns-btn ns-btn-wa-hero" aria-label="Escribir por WhatsApp">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zm-8.5 17a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5zm5-6.7c-.3-.1-1.6-.8-1.9-.9s-.4-.1-.6.2-.7.8-.8 1-.3.1-.6 0a7.4 7.4 0 0 1-3.6-3.2c-.3-.5.3-.5.8-1.6.1-.2 0-.4 0-.5l-.9-2.1c-.2-.5-.5-.4-.6-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-1 2.3c0 1.4 1 2.7 1.2 2.9s2 3.1 5 4.3c.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.6-.7 1.9-1.3.2-.7.2-1.2.2-1.3-.1-.2-.3-.3-.6-.4z"/></svg>
        WhatsApp
      </a>
    </div>


  </div>

  <a href="#ns-about-title" class="ns-hero__scroll" aria-label="Continuar"><span></span></a>
</header>

<style>
  /* ── Hero ── */
  .ns-hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;overflow:hidden;color:#fff;isolation:isolate;}
  /* Staggered entry animations */
  .ns-hero-anim{opacity:0;transform:translateY(28px);animation:ns-fadeup .7s var(--ns-ease) var(--d,0ms) forwards;}
  @keyframes ns-fadeup{to{opacity:1;transform:none;}}
  /* Watermark */
  .ns-hero__watermark{
    position:absolute;bottom:-20px;right:-10px;
    font-family:'DM Sans',sans-serif;font-weight:700;
    font-size:clamp(120px,18vw,220px);letter-spacing:-.05em;line-height:1;
    color:rgba(255,255,255,0.04);pointer-events:none;user-select:none;
    animation:ns-fadeup 1.2s var(--ns-ease) 600ms forwards;opacity:0;
  }
  /* Vertical ticker */
  .ns-hero__ticker{
    position:absolute;right:28px;top:0;bottom:0;
    display:flex;align-items:center;
    writing-mode:vertical-rl;text-orientation:mixed;
    overflow:hidden;width:20px;z-index:2;
  }
  .ns-hero__ticker-track{
    display:flex;flex-direction:column;gap:32px;
    animation:ns-ticker 22s linear infinite;
    font-size:.65rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;
    color:rgba(255,255,255,0.25);white-space:nowrap;
  }
  @keyframes ns-ticker{0%{transform:translateY(0);}100%{transform:translateY(-50%);}}
  /* Pulse on primary CTA */
  .ns-btn-pulse{position:relative;}
  .ns-btn-pulse::after{
    content:'';position:absolute;inset:-4px;border-radius:999px;
    border:1.5px solid var(--ns-blue-400);opacity:0;
    animation:ns-pulse 2.8s ease 2s infinite;
  }
  @keyframes ns-pulse{0%{opacity:.5;transform:scale(1);}70%{opacity:0;transform:scale(1.12);}100%{opacity:0;}}
  /* WhatsApp hero button with tooltip */
  .ns-btn-wa-hero{
    background:transparent;color:#fff;border:1px solid rgba(255,255,255,.4);
    position:relative;
  }
  .ns-btn-wa-hero:hover{background:rgba(37,211,102,.15);border-color:#25D366;}
  .ns-btn-wa-hero::after{
    content:'Respondemos en < 24h';
    position:absolute;bottom:calc(100% + 10px);left:50%;transform:translateX(-50%);
    background:#25D366;color:#fff;font-size:.72rem;font-weight:600;white-space:nowrap;
    padding:6px 12px;border-radius:6px;
    opacity:0;pointer-events:none;transition:opacity .2s;
  }
  .ns-btn-wa-hero:hover::after{opacity:1;}
  .ns-hero__media{
    position:absolute;inset:0;z-index:-1;
    background: #001829;
  }
  .ns-hero__media img{
    width:100%;height:100%;object-fit:cover;
    opacity:0.55;
    display:block;
  }
  .ns-hero__veil{
    position:absolute;inset:0;
    background:
      linear-gradient(180deg, rgba(0,18,36,.4) 0%, rgba(0,18,36,.05) 50%, rgba(0,18,36,.7) 100%);
  }
  .ns-hero__inner{padding:clamp(100px,14vw,140px) 24px clamp(70px,9vw,120px);}
  .ns-hero__eyebrow{color:#7fd0b3;margin-bottom:28px;}
  .ns-hero__eyebrow::before{background:#7fd0b3;}
  .ns-hero__title{color:#fff;max-width:18ch;}
  .ns-hero__title em{font-style:italic;color:#bfe6d6;font-weight:400;}
  .ns-hero__sub{margin:26px 0 38px;font-size:1.15rem;line-height:1.6;color:rgba(255,255,255,.86);max-width:58ch;}
  .ns-hero__ctas{display:flex;flex-wrap:wrap;gap:14px;margin-bottom:42px;}
  .ns-hero__trust{
    display:flex;flex-wrap:wrap;gap:28px;list-style:none;padding:0;margin:0;
    font-size:.88rem;color:rgba(255,255,255,.78);
  }
  .ns-hero__trust span{color:var(--ns-teal-600);margin-right:8px;}
  .ns-hero__scroll{
    position:absolute;bottom:26px;left:50%;transform:translateX(-50%);
    width:24px;height:38px;border:1px solid rgba(255,255,255,.5);border-radius:14px;
    display:flex;justify-content:center;padding-top:7px;
  }
  .ns-hero__scroll span{
    display:block;width:2px;height:8px;background:#fff;border-radius:2px;
    animation:ns-scroll 1.8s var(--ns-ease) infinite;
  }
  @keyframes ns-scroll{0%{transform:translateY(0);opacity:1;}70%{transform:translateY(10px);opacity:0;}100%{opacity:0;}}

  @media (max-width:760px){
    .ns-hero__sub{font-size:1rem;}
    .ns-hero__trust{gap:14px;font-size:.82rem;}
  }
