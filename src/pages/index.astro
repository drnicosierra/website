<script>
(function(){
  var track = document.getElementById('nsCasosTrack');
  var dotsWrap = document.getElementById('nsCasosDots');
  var prevBtn = document.getElementById('nsCasosPrev');
  var nextBtn = document.getElementById('nsCasosNext');
  if(!track) return;

  var cards = Array.from(track.querySelectorAll('.ns-ccase'));
  var total = cards.length;
  var current = 1;

  /* Build dots */
  cards.forEach(function(_, i){
    var d = document.createElement('button');
    d.className = 'ns-cdot';
    d.setAttribute('aria-label', 'Ir al caso ' + (i+1));
    d.setAttribute('role','tab');
    d.addEventListener('click', function(){ goTo(i); });
    dotsWrap.appendChild(d);
  });
  var dots = Array.from(dotsWrap.querySelectorAll('.ns-cdot'));

  function goTo(idx){
    current = (idx + total) % total;
    render();
  }

  function render(){
    var cardW = cards[0].offsetWidth + 24; /* card width + gap */
    var wrapW = track.parentElement.offsetWidth;
    /* Center active card */
    var offset = (wrapW / 2) - (cardW / 2) - (current * cardW);
    track.style.transform = 'translateX(' + offset + 'px)';

    cards.forEach(function(c, i){
      c.classList.remove('is-active','is-adjacent');
      if(i === current) c.classList.add('is-active');
      else if(i === current - 1 || i === current + 1) c.classList.add('is-adjacent');
    });

    dots.forEach(function(d,i){ d.classList.toggle('is-active', i === current); });
    var fill = document.getElementById('nsCasosProgressFill');
    if(fill) fill.style.width = ((current / (total - 1)) * 100) + '%';
    if(prevBtn) prevBtn.disabled = false;
    if(nextBtn) nextBtn.disabled = false;
  }

  if(prevBtn) prevBtn.addEventListener('click', function(){ goTo(current - 1); });
  if(nextBtn) nextBtn.addEventListener('click', function(){ goTo(current + 1); });

  /* Drag / swipe */
  var startX = 0, startCurrent = 0, dragging = false;
  track.addEventListener('mousedown', function(e){
    dragging = true; startX = e.clientX; startCurrent = current;
    track.classList.add('is-dragging');
  });
  window.addEventListener('mousemove', function(e){
    if(!dragging) return;
    var diff = e.clientX - startX;
    var cardW = cards[0].offsetWidth + 24;
    if(Math.abs(diff) > cardW * 0.3){
      goTo(startCurrent - Math.sign(diff));
      dragging = false;
      track.classList.remove('is-dragging');
    }
  });
  window.addEventListener('mouseup', function(){
    dragging = false;
    track.classList.remove('is-dragging');
  });
  /* Touch */
  track.addEventListener('touchstart', function(e){ startX = e.touches[0].clientX; startCurrent = current; }, {passive:true});
  track.addEventListener('touchend', function(e){
    var diff = e.changedTouches[0].clientX - startX;
    var cardW = cards[0].offsetWidth + 24;
    if(Math.abs(diff) > cardW * 0.25) goTo(startCurrent - Math.sign(diff));
  }, {passive:true});

  /* Init + resize */
  render();
  window.addEventListener('resize', render);
})();
</script>


