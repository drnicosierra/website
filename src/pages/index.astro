---
import Layout from "../layouts/Layout.astro";
import { getImage } from 'astro:assets';
import '../styles/home.css';
import dmSans700 from '@fontsource/dm-sans/files/dm-sans-latin-700-normal.woff2?url';

const heroImage = await getImage({
  src: 'https://images.unsplash.com/photo-1551076805-e1869033e561?w=1800&h=1200&q=85&fit=crop',
  width: 1800,
  height: 1200,
  format: 'webp'
});

const svcNam = await getImage({ src: 'https://images.unsplash.com/photo-1584515933487-779824d29309?w=1200&h=800&q=80&fit=crop', width: 1200, height: 800, format: 'webp' });
const svcLabio = await getImage({ src: 'https://images.unsplash.com/photo-1631815588090-d4bfec5b1ccb?w=1200&h=800&q=80&fit=crop', width: 1200, height: 800, format: 'webp' });
const svcPaladar = await getImage({ src: 'https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=1200&h=800&q=80&fit=crop', width: 1200, height: 800, format: 'webp' });
const svcRevision = await getImage({ src: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=1200&h=800&q=80&fit=crop', width: 1200, height: 800, format: 'webp' });
const svcEncia = await getImage({ src: 'https://images.unsplash.com/photo-1606811971618-4486d14f3f99?w=1200&h=800&q=80&fit=crop', width: 1200, height: 800, format: 'webp' });
const svcOrtognatica = await getImage({ src: 'https://images.unsplash.com/photo-1579154204601-01588f351e67?w=1200&h=800&q=80&fit=crop', width: 1200, height: 800, format: 'webp' });
const svcRinoplastia = await getImage({ src: 'https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=1200&h=800&q=80&fit=crop', width: 1200, height: 800, format: 'webp' });
const svcOtros = await getImage({ src: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=1200&h=800&q=80&fit=crop', width: 1200, height: 800, format: 'webp' });

const doctorPhoto = await getImage({ src: 'https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=800&h=1067&q=85&fit=crop&crop=faces', width: 800, height: 1067, format: 'webp' });

const galleryUrls = [
  'https://images.unsplash.com/photo-1555252333-9f8e92e65df9?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1516627145497-ae6968895b74?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1542909168-82c3e7fdca5c?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1499996860823-5214fcc65f8f?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1504257432389-52343af06ae3?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1552058544-f2b08422138a?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1527980965255-d3b416303d12?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1547425260-76bcadfb4f2c?w=400&h=340&q=80&fit=crop&crop=faces',
  'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&h=340&q=80&fit=crop&crop=faces'
];
const galleryImages = await Promise.all(
  galleryUrls.map((src) => getImage({ src, width: 400, height: 340, format: 'webp' }))
);

const title = 'Dr. Nico Sierra — Especialista en Fisura Labiopalatina | Barcelona';
const description = 'Dr. Nico Sierra, cirujano dedicado exclusivamente a la fisura labiopalatina en Barcelona. Reconstrucción de labio fisurado, paladar hendido y cirugía de revisión para pacientes nacionales e internacionales.';
const canonical = 'https://www.drnicosierra.com/';
const ogTitle = 'Dr. Nico Sierra — Especialista en Fisura Labiopalatina';
const ogDescription = 'Atención quirúrgica integral para fisura labiopalatina. Una práctica dedicada, en Barcelona, para familias de toda España y el extranjero.';
const ogImageOptimized = await getImage({ src: 'https://images.unsplash.com/photo-1551076805-e1869033e561?w=1200&h=630&q=80&fit=crop', width: 1200, height: 630, format: 'jpg' });
const ogImage = new URL(ogImageOptimized.src, Astro.site).href;
const keywords = 'fisura labiopalatina, labio fisurado, paladar hendido, FLP, cirugía de revisión, Dr. Nico Sierra, cirujano Barcelona, NAM, ortognática FLP, rinoplastia FLP';
---
<Layout title={title} description={description} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDescription} ogImage={ogImage} keywords={keywords}>
  <Fragment slot="head" set:html={`
<link rel="preload" as="font" type="font/woff2" href="${dmSans700}" crossorigin>
`} />
  <Fragment set:html={`
<!-- ============================================================================
  GLOBAL DARK BACKGROUND — gradient narrative + breathing light orb
  This goes on the <body> or a full-page wrapper in Webflow
============================================================================ -->

<!-- Orb elements — inject once, outside sections -->
<div class="ns-orb ns-orb-1" id="nsOrb1" aria-hidden="true"></div>
<div class="ns-orb ns-orb-2" id="nsOrb2" aria-hidden="true"></div>





<!-- ============================================================================
  BLOCK 4 — HERO
  Paste into: Webflow Embed (first section under navbar)
============================================================================ -->
<header class="ns-scope ns-hero" role="banner">
  <div class="ns-hero__media">
    <img src="${heroImage.src}" alt="Dr. Nico Sierra — Especialista en fisura labiopalatina">
    <div class="ns-hero__veil" aria-hidden="true"></div>
  </div>

  <!-- Watermark number — bottom right -->
  <div class="ns-hero__watermark" aria-hidden="true">+1.000</div>

  <!-- Vertical ticker — right edge -->
  <div class="ns-hero__ticker" aria-hidden="true">
    <div class="ns-hero__ticker-track">
      <span>Fisura labiopalatina</span><span>Barcelona · España</span>
      <span>Labio fisurado</span><span>Paladar hendido</span>
      <span>Cirugía de revisión</span><span>Operation Smile</span>
      <span>Smile Train</span><span>Pacientes internacionales</span>
      <span>Fisura labiopalatina</span><span>Barcelona · España</span>
      <span>Labio fisurado</span><span>Paladar hendido</span>
    </div>
  </div>

  <div class="ns-container ns-hero__inner">
    <span class="ns-eyebrow ns-hero__eyebrow ns-hero-anim" style="--d:0ms">Especialista en fisura labiopalatina (labio y paladar hendido). Barcelona</span>
    <h1 class="ns-h1 ns-hero__title ns-hero-anim" style="--d:60ms">
      Una práctica dedicada<br>
      <em>en exclusiva</em> a la fisura labiopalatina.
    </h1>
    <p class="ns-hero__sub ns-hero-anim" style="--d:120ms">
      Atención quirúrgica altamente especializada en todas las etapas del desarrollo — desde el diagnóstico prenatal hasta la cirugía de revisión en la edad adulta. Casos primarios, secuelas complejas y familias de toda España y Europa.
    </p>

    <div class="ns-hero__ctas ns-hero-anim" style="--d:180ms">
      <a href="/cuentanos-tu-historia" class="ns-btn ns-btn-primary ns-btn-pulse">Cuéntanos tu caso</a>
      <a href="https://wa.me/WHATSAPP_NUMBER" class="btn btn-wa" data-wa-loc="hero" aria-label="Escribir por WhatsApp">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zm-8.5 17a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5zm5-6.7c-.3-.1-1.6-.8-1.9-.9s-.4-.1-.6.2-.7.8-.8 1-.3.1-.6 0a7.4 7.4 0 0 1-3.6-3.2c-.3-.5.3-.5.8-1.6.1-.2 0-.4 0-.5l-.9-2.1c-.2-.5-.5-.4-.6-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-1 2.3c0 1.4 1 2.7 1.2 2.9s2 3.1 5 4.3c.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.6-.7 1.9-1.3.2-.7.2-1.2.2-1.3-.1-.2-.3-.3-.6-.4z"/></svg>
        WhatsApp
      </a>
    </div>


  </div>

  <a href="#ns-about-title" class="ns-hero__scroll" aria-label="Continuar"><span></span></a>
</header>



<!-- ============================================================================
  BLOCK 5 — TRUST STRIP
  Paste into: Webflow Embed
============================================================================ -->



<!-- ============================================================================
  BLOCK 6 — ABOUT DR. SIERRA
  Paste into: Webflow Embed
============================================================================ -->
<section class="ns-scope ns-section ns-about ns-section-teal" aria-labelledby="ns-about-title">
  <div class="ns-container">

    <!-- Row 1: image + text side by side, top-aligned -->
    <div class="ns-about__top">
      <figure class="ns-about__media ns-reveal">
        <img src="${doctorPhoto.src}" alt="Dr. Nico Sierra — Especialista en fisura labiopalatina" loading="lazy">
        <div class="ns-about__media-mark" aria-hidden="true"></div>
      </figure>
      <div class="ns-about__text">
        <div class="ns-sh">
          <span class="ns-eyebrow">Sobre Dr. Nico Sierra</span>
          <h2 id="ns-about-title" class="ns-h2 ns-about__title ns-reveal">Una carrera dedicada en exclusiva a las personas nacidas con fisura labiopalatina.</h2>
        </div>
        <div class="ns-about__body ns-reveal">
          <p>Con más de 100 cirugías anuales, el Dr. Nico Sierra acompaña a cada paciente desde el primer momento con un plan de tratamiento completamente personalizado, diseñado para dar respuesta a sus necesidades físicas, funcionales y emocionales en cada etapa de su desarrollo.</p>
          <p>Referente nacional e internacional en cirugía reconstructiva de fisura labiopalatina, su enfoque integra las especialidades médicas y odontológicas necesarias en cada fase, coordinando equipos interdisciplinares con el rigor y la experiencia que cada caso exige.</p>
          <p>Aplica técnicas avanzadas y mínimamente invasivas para restaurar la estética y la función del rostro, reduciendo al máximo las molestias postoperatorias y favoreciendo siempre la recuperación más rápida y confortable posible.</p>
          <p>Es especialista de referencia para quienes necesitan corregir las secuelas de tratamientos previos. Con amplia experiencia en casos de alta complejidad, su objetivo es siempre el mismo: devolver la armonía facial, la función y, sobre todo, la confianza y la autoestima a pacientes de todas las edades. Porque nunca es tarde para sentirse mejor.</p>
        </div>
      </div>
    </div>

    <!-- 5 credentials full-width below -->
    <div class="ns-about__bottom ns-reveal">
      <ul class="ns-about__creds ns-about__creds--5" role="list">
        <li class="ns-cred">
          <div class="ns-cred__icon" style="--ci:#008362">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div><strong>Más de 1.000 cirugías</strong><span>Más de 100 cada año. La experiencia importa.</span></div>
        </li>
        <li class="ns-cred">
          <div class="ns-cred__icon" style="--ci:#7C3AED">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <div><strong>Fellowship en Cirugía Craneofacial y FLP</strong><span>El único cirujano en España con esta subespecialidad.</span></div>
        </li>
        <li class="ns-cred">
          <div class="ns-cred__icon" style="--ci:#0891B2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div><strong>Técnicas avanzadas y mínimamente invasivas</strong><span>Estética y función con el máximo confort.</span></div>
        </li>
        <li class="ns-cred">
          <div class="ns-cred__icon" style="--ci:#C9186A">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <div><strong>Experto en cirugía de revisión</strong><span>Nunca es tarde para sentirse mejor.</span></div>
        </li>
        <li class="ns-cred">
          <div class="ns-cred__icon" style="--ci:#0d74c4">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div><strong>Pacientes de toda España y Europa</strong><span>Valoración por telemedicina. Logística coordinada.</span></div>
        </li>
      </ul>
      <a href="/sobre-dr-nico-sierra" class="ns-btn ns-btn-outline ns-about__cta">Conoce al Dr. Nico Sierra</a>
    </div>

  </div>
</section>




<!-- ============================================================================
  PATIENT JOURNEY TIMELINE — animated draw-on-scroll
  Shows the typical FLP patient pathway across all 8 services
============================================================================ -->
<section class="ns-scope ns-section ns-timeline" aria-labelledby="ns-timeline-title">
  <div class="ns-container">
    <header class="ns-timeline__head ns-reveal ns-sh ns-sh--center">
      <span class="ns-eyebrow">El camino de cada paciente</span>
      <h2 id="ns-timeline-title" class="ns-h2">Un recorrido que puede<br>durar toda la vida.</h2>
      <p class="ns-lead" style="max-width:52ch;">La fisura labiopalatina no se trata en una sola visita. El Dr. Sierra acompaña a cada paciente a través de todas las etapas que necesite — sin prisa, sin saltar pasos.</p>
    </header>

    <!-- Timeline track -->
    <div class="ns-tl" id="nsTl" aria-label="Recorrido del paciente FLP">

      <!-- SVG connecting line — drawn on scroll -->
      <svg class="ns-tl__line-svg" aria-hidden="true" preserveAspectRatio="none">
        <path class="ns-tl__line-path" id="nsTlPath" d=""/>
      </svg>

      <!-- Timeline nodes -->
      <div class="ns-tl__nodes">

        <div class="ns-tl__node ns-reveal" style="--sc:#7C3AED" data-href="/nam">
          <div class="ns-tl__node-dot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          </div>
          <div class="ns-tl__node-content">
            <span class="ns-tl__node-num">01</span>
            <h3 class="ns-tl__node-name">NAM<br><em>Pre-operatoria</em></h3>
            <p>Moldeado nasoalveolar previo a la primera cirugía.</p>
            <a href="/nam" class="ns-tl__node-link">Ver →</a>
          </div>
        </div>

        <div class="ns-tl__node ns-reveal" style="--sc:#C9186A" data-href="/labio-fisurado">
          <div class="ns-tl__node-dot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <div class="ns-tl__node-content">
            <span class="ns-tl__node-num">02</span>
            <h3 class="ns-tl__node-name">Labio<br><em>Fisurado</em></h3>
            <p>Reconstrucción primaria del labio fisurado.</p>
            <a href="/labio-fisurado" class="ns-tl__node-link">Ver →</a>
          </div>
        </div>

        <div class="ns-tl__node ns-reveal" style="--sc:#008362" data-href="/paladar-hendido">
          <div class="ns-tl__node-dot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="ns-tl__node-content">
            <span class="ns-tl__node-num">03</span>
            <h3 class="ns-tl__node-name">Paladar<br><em>Hendido</em></h3>
            <p>Cierre del paladar para el habla y la alimentación.</p>
            <a href="/paladar-hendido" class="ns-tl__node-link">Ver →</a>
          </div>
        </div>

        <div class="ns-tl__node ns-reveal" style="--sc:#16A34A" data-href="/encia">
          <div class="ns-tl__node-dot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </div>
          <div class="ns-tl__node-content">
            <span class="ns-tl__node-num">04</span>
            <h3 class="ns-tl__node-name">Encía<br><em>Injerto óseo</em></h3>
            <p>Reconstrucción alveolar para los dientes definitivos.</p>
            <a href="/encia" class="ns-tl__node-link">Ver →</a>
          </div>
        </div>

        <div class="ns-tl__node ns-reveal" style="--sc:#B45309" data-href="/ortognatica">
          <div class="ns-tl__node-dot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="ns-tl__node-content">
            <span class="ns-tl__node-num">05</span>
            <h3 class="ns-tl__node-name">Ortognática<br><em>en FLP</em></h3>
            <p>Corrección maxilomandibular y armonía facial.</p>
            <a href="/ortognatica" class="ns-tl__node-link">Ver →</a>
          </div>
        </div>

        <div class="ns-tl__node ns-reveal" style="--sc:#0891B2" data-href="/rinoplastia">
          <div class="ns-tl__node-dot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <div class="ns-tl__node-content">
            <span class="ns-tl__node-num">06</span>
            <h3 class="ns-tl__node-name">Rinoplastia<br><em>en FLP</em></h3>
            <p>Reconstrucción nasal funcional y estética.</p>
            <a href="/rinoplastia" class="ns-tl__node-link">Ver →</a>
          </div>
        </div>

        <div class="ns-tl__node ns-reveal" style="--sc:#0d74c4" data-href="/cirugia-revision">
          <div class="ns-tl__node-dot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          </div>
          <div class="ns-tl__node-content">
            <span class="ns-tl__node-num">07</span>
            <h3 class="ns-tl__node-name">Cirugía de<br><em>Revisión</em></h3>
            <p>Corrección de resultados previos en cualquier etapa.</p>
            <a href="/cirugia-revision" class="ns-tl__node-link">Ver →</a>
          </div>
        </div>

        <div class="ns-tl__node ns-tl__node--open ns-reveal" style="--sc:#64748B" data-href="/cuentanos-tu-historia">
          <div class="ns-tl__node-dot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
          </div>
          <div class="ns-tl__node-content">
            <span class="ns-tl__node-num">+</span>
            <h3 class="ns-tl__node-name">Tu caso<br><em>es único</em></h3>
            <p>No todos los recorridos son iguales. Cuéntanos el tuyo.</p>
            <a href="/cuentanos-tu-historia" class="ns-tl__node-link ns-tl__node-link--cta">Escríbenos →</a>
          </div>
        </div>

      </div><!-- /nodes -->
    </div><!-- /tl -->
  </div>
</section>


<script>
(function(){
  var tl = document.getElementById('nsTl');
  if(!tl) return;
  /* Draw-on-scroll trigger */
  if('IntersectionObserver' in window){
    var tlObs = new IntersectionObserver(function(entries){
      if(entries[0].isIntersecting){ tl.classList.add('is-drawing'); tlObs.disconnect(); }
    },{threshold:.3});
    tlObs.observe(tl);
  }
  /* Click anywhere on node → navigate */
  tl.querySelectorAll('.ns-tl__node').forEach(function(n){
    n.addEventListener('click', function(){
      var href = n.getAttribute('data-href');
      if(href) window.location.href = href;
