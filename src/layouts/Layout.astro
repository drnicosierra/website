---
import '../styles/global.css';
import dmSans500 from '@fontsource/dm-sans/files/dm-sans-latin-500-normal.woff2?url';
import spaceGrotesk400 from '@fontsource/space-grotesk/files/space-grotesk-latin-400-normal.woff2?url';
import spaceGrotesk600 from '@fontsource/space-grotesk/files/space-grotesk-latin-600-normal.woff2?url';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  keywords?: string;
  schemaBlocks?: string; // raw <script type="application/ld+json">...</script> markup, one or more, concatenated
}

const {
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage = "https://images.unsplash.com/photo-1551076805-e1869033e561?w=1800&q=85&fit=crop",
  keywords,
  schemaBlocks = "",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="preload" as="font" type="font/woff2" href={dmSans500} crossorigin>
<link rel="preload" as="font" type="font/woff2" href={spaceGrotesk400} crossorigin>
<link rel="preload" as="font" type="font/woff2" href={spaceGrotesk600} crossorigin>

<title>{title}</title>
<meta name="description" content={description}>
{keywords && <meta name="keywords" content={keywords}>}
<meta name="author" content="Dr. Nico Sierra">
<link rel="canonical" href={canonical}>

<meta property="og:type" content="website">
<meta property="og:title" content={ogTitle}>
<meta property="og:description" content={ogDescription}>
<meta property="og:image" content={ogImage}>
<meta property="og:url" content={canonical}>
<meta property="og:locale" content="es_ES">
<meta name="twitter:card" content="summary_large_image">

<!-- WhatsApp click tracking -->
<script is:inline>
document.addEventListener('click', function(e) {
  var waLink = e.target.closest('.btn-wa, .wa-float');
  if (!waLink) return;
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: 'whatsapp_click',
    wa_location: waLink.getAttribute('data-wa-loc') || 'unknown',
    page_path: window.location.pathname
  });
});
</script>

<!-- Google Tag Manager -->
<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-MCNLW9Z4');</script>
<!-- End Google Tag Manager -->

<Fragment set:html={schemaBlocks} />


<slot name="head" />
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MCNLW9Z4"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
<nav class="nav" id="pageNav">
  <div class="nav-inner">
    <a href="/" aria-label="Dr. Nico Sierra — Inicio">
      <img src="/logo_white_transparent.webp" alt="Dr. Nico Sierra" width="117" height="72" fetchpriority="high" style="height:72px;width:auto;">
    </a>
    <ul class="nav-links" id="pageNavLinks">
      <li class="nav-item nav-item--dropdown">
        <div class="nav-item__row">
          <a href="/como-te-ayudamos/">Tratamientos</a>
          <button class="nav-item__toggle" aria-expanded="false" aria-label="Mostrar lista de tratamientos">
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
        <div class="nav-dropdown">
          <a href="/ortopedia-prequirurgica-nam/">Ortopedia Pre-operatoria NAM</a>
          <a href="/cirugia-labio-fisurado/">Reconstrucción de Labio Fisurado</a>
          <a href="/cirugia-paladar-hendido/">Reconstrucción de Paladar Hendido</a>
          <a href="/injerto-oseo-alveolar/">Reconstrucción de Encía (Injerto Óseo)</a>
          <a href="/cirugia-ortognatica-flp/">Cirugía Ortognática en FLP</a>
          <a href="/rinoplastia-flp/">Rinoplastia en FLP</a>
          <a href="/cirugia-revision-fisura/">Cirugía de Revisión</a>
          <a href="/otros-procedimientos/">Otros Procedimientos</a>
        </div>
      </li>
      <li><a href="/sobre-dr-nico-sierra/">Dr. Sierra</a></li>
      <li><a href="/vidas-transformadas/">Resultados</a></li>
      <li><a href="/tu-camino-con-nosotros/">Tu camino</a></li>
      <li><a href="/blog-y-articulos/">Artículos</a></li>
    </ul>
    <div class="nav-actions">
      <a href="/cuentanos-tu-historia/" class="btn nav-cta">Cuéntanos tu caso</a>
      <button class="nav-burger" id="navBurger" aria-label="Abrir menú" aria-expanded="false" aria-controls="pageNavLinks">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<slot />

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <img src="/logo_white_transparent.webp" alt="Dr. Nico Sierra" class="footer-logo" width="78" height="48" style="height:48px;width:auto;filter:brightness(0) invert(1);opacity:.8;">
        <p class="footer-desc">Especialista en fisura labiopalatina en España. Cirugía de labio fisurado, paladar hendido y cirugía de revisión en Barcelona.</p>
        <a href="mailto:cuentame@drnicosierra.com" style="font-size:.88rem;color:rgba(255,255,255,.5)">cuentame@drnicosierra.com</a>
      </div>
      <div class="footer-col">
        <h3>Tratamientos</h3>
        <ul>
          <li><a href="/ortopedia-prequirurgica-nam/">Ortopedia NAM</a></li>
          <li><a href="/cirugia-labio-fisurado/">Labio fisurado</a></li>
          <li><a href="/cirugia-paladar-hendido/">Paladar hendido</a></li>
          <li><a href="/cirugia-revision-fisura/">Cirugía de revisión</a></li>
          <li><a href="/injerto-oseo-alveolar/">Reconstrucción de encía</a></li>
          <li><a href="/cirugia-ortognatica-flp/">Cirugía ortognática</a></li>
          <li><a href="/rinoplastia-flp/">Rinoplastia FLP</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Información</h3>
        <ul>
          <li><a href="/sobre-dr-nico-sierra/">Sobre el Dr. Sierra</a></li>
          <li><a href="/vidas-transformadas/">Resultados</a></li>
          <li><a href="/tu-camino-con-nosotros/">Tu camino con nosotros</a></li>
          <li><a href="/blog-y-articulos/">Blog y artículos</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Contacto</h3>
        <ul>
          <li><a href="/cuentanos-tu-historia/">Envía tu caso</a></li>
          <li><a href="https://wa.me/WHATSAPP_NUMBER">WhatsApp</a></li>
          <li><a href="mailto:cuentame@drnicosierra.com">Email</a></li>
          <li><a href="/politica-de-privacidad/">Política de privacidad</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-base">
      <p>© <span id="yr">2025</span> Dr. Nico Sierra. Todos los derechos reservados.</p>
      <p>Barcelona, España · <a href="/politica-de-privacidad/">Política de privacidad</a></p>
    </div>
  </div>
</footer>

<a href="https://wa.me/WHATSAPP_NUMBER" class="wa-float" data-wa-loc="float" aria-label="Escríbenos por WhatsApp">
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zM12 20.5a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5z"/></svg>
  <span class="wa-tip">Escríbenos — respondemos en &lt;24h</span>
</a>

<script is:inline>
(function(){
  var nav = document.getElementById('pageNav');
  if(nav){
    var onScroll = function(){ nav.classList.toggle('scrolled', window.scrollY > 24); };
    window.addEventListener('scroll', onScroll, {passive:true});
    onScroll();
  }
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, {threshold:.1, rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.reveal, .reveal-scale').forEach(function(el){ io.observe(el); });
  } else {
    document.querySelectorAll('.reveal, .reveal-scale').forEach(function(el){ el.classList.add('visible'); });
  }
  var yr = document.getElementById('yr');
  if(yr) yr.textContent = new Date().getFullYear();

  var burger = document.getElementById('navBurger');
  var navLinks = document.getElementById('pageNavLinks');
  if(burger && navLinks){
    burger.addEventListener('click', function(){
      var open = navLinks.getAttribute('data-open') === 'true';
      navLinks.setAttribute('data-open', String(!open));
      burger.setAttribute('aria-expanded', String(!open));
    });
    navLinks.querySelectorAll('a').forEach(function(a){
      a.addEventListener('click', function(){
        navLinks.setAttribute('data-open', 'false');
        burger.setAttribute('aria-expanded', 'false');
      });
    });
  }

  var navItemToggle = document.querySelector('.nav-item__toggle');
  var navItemDD = document.querySelector('.nav-item--dropdown');
  if(navItemToggle && navItemDD){
    // Mobile: tap the chevron to expand/collapse inline (chevron is
    // display:none on desktop via CSS, so this only ever fires on mobile).
    navItemToggle.addEventListener('click', function(e){
      e.preventDefault();
      var open = navItemDD.classList.toggle('nav-item--open');
      navItemToggle.setAttribute('aria-expanded', String(open));
    });

    // Desktop: hover-intent with a short close delay, so crossing the
    // gap between the link and the dropdown doesn't slam it shut.
    var closeTimer = null;
    navItemDD.addEventListener('mouseenter', function(){
      clearTimeout(closeTimer);
      navItemDD.classList.add('nav-item--open');
    });
    navItemDD.addEventListener('mouseleave', function(){
      clearTimeout(closeTimer);
      closeTimer = setTimeout(function(){
        navItemDD.classList.remove('nav-item--open');
      }, 250);
    });
  }
})();
</script>
</body>
</html>
