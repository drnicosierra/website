---
export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  keywords?: string;
  schemaBlocks?: string; // raw <script type="application/ld+json">...</script> markup, one or more, concatenated
}

const {
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage = "https://images.unsplash.com/photo-1551076805-e1869033e561?w=1800&q=85&fit=crop",
  keywords,
  schemaBlocks = "",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>{title}</title>
<meta name="description" content={description}>
{keywords && <meta name="keywords" content={keywords}>}
<meta name="author" content="Dr. Nico Sierra">
<link rel="canonical" href={canonical}>

<meta property="og:type" content="website">
<meta property="og:title" content={ogTitle}>
<meta property="og:description" content={ogDescription}>
<meta property="og:image" content={ogImage}>
<meta property="og:url" content={canonical}>
<meta property="og:locale" content="es_ES">
<meta name="twitter:card" content="summary_large_image">

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-C6SCF6WY7Q"></script>
<script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-C6SCF6WY7Q');</script>
<!-- GTM -->
<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-MCNLW9Z4');</script>

<Fragment set:html={schemaBlocks} />

<style is:global>
/* ═══════════════════════════════════════════════════
   GLOBAL CHROME — nav, footer, WhatsApp float, base .btn
   This is the ONLY CSS Layout.astro owns. It exists so the
   nav/footer/CTA markup below (hardcoded here, identical on
   every page) always renders correctly, even on pages whose
   own injected CSS uses a different naming convention (e.g.
   the homepage's ns-* classes) and never defines .nav/.footer.
   Page-specific design (typography, sections, colors) stays
   in each page's own <style> block — do not add page content
   rules here.
   ═══════════════════════════════════════════════════ */
:root {
  --ns-blue-900:#001829;
  --ns-blue-800:#001e3a;
  --ns-blue-700:#002d52;
  --ns-blue-600:#003a63;
  --ns-blue-500:#005085;
  --ns-blue-400:#0d74c4;
  --ns-teal-600:#008362;
  --ns-teal-300:#4db896;
  --ns-ink:#e8edf2;
  --ns-whatsapp:#25D366;
  --ns-ease:cubic-bezier(.22,.61,.36,1);
  --ns-container:1240px;
  --sc: var(--ns-teal-600); /* service pages override this per-page; safe default here */
}
*, *::before, *::after { box-sizing:border-box; }
.container { max-width:var(--ns-container); margin:0 auto; padding:0 clamp(20px,4vw,48px); }

/* Buttons */
.btn {
  display:inline-flex; align-items:center; gap:.6rem;
  padding:14px 26px; border-radius:999px;
  font-family:'DM Sans',sans-serif; font-weight:500; font-size:.95rem;
  transition:all .25s var(--ns-ease); cursor:pointer; border:none;
  text-decoration:none;
}

/* Navbar */
.nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  height:80px; display:flex; align-items:center;
  background:rgba(0,22,38,0.3); backdrop-filter:blur(8px);
  border-bottom:1px solid rgba(0,131,98,0.2);
  transition:background .35s var(--ns-ease), border-color .35s;
}
.nav.scrolled {
  background:rgba(0,18,36,0.92);
  border-bottom-color:rgba(0,131,98,0.25);
  box-shadow:0 1px 0 rgba(255,255,255,0.04);
}
.nav-inner {
  max-width:var(--ns-container); width:100%; margin:0 auto;
  padding:0 clamp(20px,4vw,48px);
  display:flex; align-items:center; justify-content:space-between;
}
.nav-links { display:flex; align-items:center; gap:32px; list-style:none; }
.nav-links a {
  font-size:.88rem; font-weight:500; color:rgba(210,235,225,0.85);
  text-decoration:none; transition:color .2s; padding:4px 0; position:relative;
}
.nav-links a:hover { color:#fff; }
.nav-links a.active { color:var(--sc) !important; }
.nav-links a.active::after {
  content:''; position:absolute; bottom:-2px; left:0; right:0;
  height:1.5px; background:var(--sc); border-radius:2px;
}
.nav-cta {
  background:var(--ns-teal-600) !important; color:#fff !important;
  padding:10px 20px; border-radius:999px; font-size:.88rem !important;
  font-weight:600 !important;
}
.nav-cta:hover { background:var(--ns-blue-500) !important; }

/* Footer */
.footer {
  background:#000e1a; border-top:1px solid rgba(255,255,255,.07);
  color:rgba(255,255,255,.78); padding:clamp(72px,7vw,96px) 0 32px;
}
.footer-grid {
  display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:48px;
}
.footer-desc { font-size:.92rem; line-height:1.7; max-width:36ch; margin-bottom:20px; }
.footer-col h3 {
  font-family:'DM Sans',sans-serif; color:#fff; font-size:.78rem;
  letter-spacing:.18em; text-transform:uppercase; font-weight:500; margin:0 0 16px;
}
.footer-col ul { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px; }
.footer-col a { font-size:.92rem; color:rgba(255,255,255,.6); text-decoration:none; transition:color .2s; }
.footer-col a:hover { color:#fff; }
.footer-col a.active { color:var(--sc); }
.footer-base {
  margin-top:56px; padding-top:20px; border-top:1px solid rgba(255,255,255,.1);
  display:flex; justify-content:space-between; flex-wrap:wrap; gap:12px;
  font-size:.8rem; color:rgba(255,255,255,.4);
}

/* WhatsApp float button */
.wa-float {
  position:fixed; right:22px; bottom:22px; z-index:200;
  width:60px; height:60px; border-radius:50%;
  background:var(--ns-whatsapp); color:#fff;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 12px 28px rgba(37,211,102,.35);
  transition:transform .25s var(--ns-ease), box-shadow .25s;
  animation:wa-pulse 2.8s ease 5s infinite;
  cursor:pointer; text-decoration:none;
}
.wa-float:hover { transform:translateY(-2px) scale(1.04); animation:none; }
@keyframes wa-pulse {
  0%,100% { box-shadow:0 12px 28px rgba(37,211,102,.4); }
  50% { box-shadow:0 12px 40px rgba(37,211,102,.7),0 0 0 10px rgba(37,211,102,.1); }
}
.wa-tip {
  position:absolute; right:72px; top:50%; transform:translateY(-50%) translateX(6px);
  background:#001829; color:#fff; font-size:.78rem; white-space:nowrap;
  padding:7px 12px; border-radius:8px; border:1px solid rgba(0,131,98,.3);
  opacity:0; pointer-events:none; transition:opacity .2s, transform .2s;
}
.wa-float:hover .wa-tip { opacity:1; transform:translateY(-50%) translateX(0); }

@media (max-width:880px) {
  .nav-links { display:none; }
  .footer-grid { grid-template-columns:1fr; gap:32px; }
}
</style>

<slot name="head" />
</head>
<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MCNLW9Z4" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<nav class="nav" id="pageNav">
  <div class="nav-inner">
    <a href="/" aria-label="Dr. Nico Sierra — Inicio">
      <img src="/logo_white_transparent.png" alt="Dr. Nico Sierra" style="height:72px;width:auto;">
    </a>
    <ul class="nav-links">
      <li><a href="/como-te-ayudamos/">Tratamientos</a></li>
      <li><a href="/sobre-dr-nico-sierra/">Dr. Sierra</a></li>
      <li><a href="/vidas-transformadas/">Resultados</a></li>
      <li><a href="/tu-camino-con-nosotros/">Tu camino</a></li>
      <li><a href="/blog-y-articulos/">Artículos</a></li>
    </ul>
    <a href="/cuentanos-tu-historia/" class="btn nav-cta">Cuéntanos tu caso</a>
  </div>
</nav>

<slot />

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <img src="/logo_white_transparent.png" alt="Dr. Nico Sierra" class="footer-logo" style="height:48px;width:auto;filter:brightness(0) invert(1);opacity:.8;">
        <p class="footer-desc">Especialista en fisura labiopalatina en España. Cirugía de labio fisurado, paladar hendido y cirugía de revisión en Barcelona.</p>
        <a href="mailto:cuentame@drnicosierra.com" style="font-size:.88rem;color:rgba(255,255,255,.5)">cuentame@drnicosierra.com</a>
      </div>
      <div class="footer-col">
        <h3>Tratamientos</h3>
        <ul>
          <li><a href="/ortopedia-prequirurgica-nam/">Ortopedia NAM</a></li>
          <li><a href="/cirugia-labio-fisurado/">Labio fisurado</a></li>
          <li><a href="/cirugia-paladar-hendido/">Paladar hendido</a></li>
          <li><a href="/cirugia-revision-fisura/">Cirugía de revisión</a></li>
          <li><a href="/injerto-oseo-alveolar/">Reconstrucción de encía</a></li>
          <li><a href="/cirugia-ortognatica-flp/">Cirugía ortognática</a></li>
          <li><a href="/rinoplastia-flp/">Rinoplastia FLP</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Información</h3>
        <ul>
          <li><a href="/sobre-dr-nico-sierra/">Sobre el Dr. Sierra</a></li>
          <li><a href="/vidas-transformadas/">Resultados</a></li>
          <li><a href="/tu-camino-con-nosotros/">Tu camino con nosotros</a></li>
          <li><a href="/blog-y-articulos/">Blog y artículos</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Contacto</h3>
        <ul>
          <li><a href="/cuentanos-tu-historia/">Envía tu caso</a></li>
          <li><a href="https://wa.me/WHATSAPP_NUMBER">WhatsApp</a></li>
          <li><a href="mailto:cuentame@drnicosierra.com">Email</a></li>
          <li><a href="/politica-de-privacidad/">Política de privacidad</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-base">
      <p>© <span id="yr">2025</span> Dr. Nico Sierra. Todos los derechos reservados.</p>
      <p>Barcelona, España · <a href="/politica-de-privacidad/">Política de privacidad</a></p>
    </div>
  </div>
</footer>

<a href="https://wa.me/WHATSAPP_NUMBER" class="wa-float" aria-label="Escríbenos por WhatsApp">
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 3.4 17l-1.4 5.1 5.2-1.4a11 11 0 0 0 13.3-17.2zM12 20.5a9 9 0 0 1-4.6-1.3l-.3-.2-3.1.8.8-3-.2-.3A9 9 0 1 1 21 12a9 9 0 0 1-9 8.5z"/></svg>
  <span class="wa-tip">Escríbenos — respondemos en &lt;24h</span>
</a>

<script is:inline>
(function(){
  var nav = document.getElementById('pageNav');
  if(nav){
    var onScroll = function(){ nav.classList.toggle('scrolled', window.scrollY > 24); };
    window.addEventListener('scroll', onScroll, {passive:true});
    onScroll();
  }
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, {threshold:.1, rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.reveal, .reveal-scale').forEach(function(el){ io.observe(el); });
  } else {
    document.querySelectorAll('.reveal, .reveal-scale').forEach(function(el){ el.classList.add('visible'); });
  }
  var yr = document.getElementById('yr');
  if(yr) yr.textContent = new Date().getFullYear();
})();
</script>
</body>
</html>
